---
---
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title>F1 Explorer</title>
    </head>
    <body>
        <div id="app">
            <select id="year-select">
                <option value="2025">2025</option>
                <option value="2024">2024</option>
                <option value="2023">2023</option>
            </select>
            <select id="meeting-select"><option value="">— Select race —</option></select>
            <select id="session-select"><option value="">— Session —</option></select>
            <select id="driver-select"><option value="">— All drivers —</option></select>

            <div id="endpoint-buttons"></div>
            <div id="url-display"></div>

            <button id="fetch-button" disabled>Fetch JSON</button>
            <button id="copy-button">Copy</button>
            <span id="status-message"></span>

            <pre id="json-output">// JSON will appear here</pre>
        </div>

        <hr />

        <h2>Track Visualiser</h2>
        <div id="track-container" style="width: 800px; height: 600px;"></div>

        <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
        <script>
            declare const THREE: any;
            // ── JSON Explorer ─────────────────────────────────────────────

            const BASE_URL = 'https://api.openf1.org/v1';
            const ENDPOINTS = [
                { label: 'Drivers', path: '/drivers' },
                { label: 'Results', path: '/session_result' },
                { label: 'Laps', path: '/laps' },
                { label: 'Stints', path: '/stints' },
                { label: 'Pit Stops', path: '/pit' },
                { label: 'Position', path: '/position' },
                { label: 'Intervals', path: '/intervals' },
                { label: 'Race Control', path: '/race_control' },
                { label: 'Weather', path: '/weather' },
                { label: 'Starting Grid', path: '/starting_grid' },
                { label: 'Team Radio', path: '/team_radio' },
                { label: 'Overtakes', path: '/overtakes' },
                { label: 'Car Data', path: '/car_data' },
            ];

            const ENDPOINTS_WITHOUT_DRIVER_FILTER = [
                '/session_result',
                '/race_control',
                '/weather',
                '/starting_grid',
            ];

            let selectedSessionKey: string | null = null;
            let selectedDriverNumber: string | null = null;
            let activeEndpointPath: string = ENDPOINTS[0].path;

            const endpointButtonsContainer = document.getElementById('endpoint-buttons');
            ENDPOINTS.forEach(endpoint => {
                const button = document.createElement('button');
                button.textContent = endpoint.label;
                button.addEventListener('click', () => {
                    activeEndpointPath = endpoint.path;
                    updateUrlDisplay();
                });
                endpointButtonsContainer?.appendChild(button);
            });

            function buildRequestUrl() {
                let url = `${BASE_URL}${activeEndpointPath}?session_key=${selectedSessionKey}`;
                const driverFilterAllowed = !ENDPOINTS_WITHOUT_DRIVER_FILTER.includes(activeEndpointPath);
                if (selectedDriverNumber && driverFilterAllowed) {
                    if (activeEndpointPath === '/overtakes') {
                        url += `&overtaking_driver_number=${selectedDriverNumber}&overtaken_driver_number=${selectedDriverNumber}`;
                    } else {
                        url += `&driver_number=${selectedDriverNumber}`;
                    }
                }
                return url;
            }

            async function fetchAndMergeOvertakes(): Promise<any[]> {
                const overtakingUrl = `${BASE_URL}/overtakes?session_key=${selectedSessionKey}&overtaking_driver_number=${selectedDriverNumber}`;
                const overtakenUrl = `${BASE_URL}/overtakes?session_key=${selectedSessionKey}&overtaken_driver_number=${selectedDriverNumber}`;

                const [overtakingResults, overtakenResults] = await Promise.all([
                    fetch(overtakingUrl).then(response => response.json()),
                    fetch(overtakenUrl).then(response => response.json()),
                ]);

                const mergedResults = [...overtakingResults, ...overtakenResults];
                mergedResults.sort((entryA: any, entryB: any) => new Date(entryA.date).getTime() - new Date(entryB.date).getTime());
                return mergedResults;
            }

            function updateUrlDisplay() {
                const urlDisplay = document.getElementById('url-display');
                if (!selectedSessionKey || !urlDisplay) return;

                if (activeEndpointPath === '/overtakes' && selectedDriverNumber) {
                    urlDisplay.textContent = `${BASE_URL}/overtakes?session_key=${selectedSessionKey}&overtaking_driver_number=${selectedDriverNumber} + overtaken_driver_number=${selectedDriverNumber} (merged)`;
                } else {
                    urlDisplay.textContent = buildRequestUrl();
                }

                (document.getElementById('fetch-button') as HTMLButtonElement).disabled = false;
            }

            async function loadMeetings() {
                const selectedYear = (document.getElementById('year-select') as HTMLSelectElement).value;
                const meetingsData = await fetch(`${BASE_URL}/meetings?year=${selectedYear}`).then(response => response.json());
                meetingsData.sort((meetingA: any, meetingB: any) => new Date(meetingA.date_start).getTime() - new Date(meetingB.date_start).getTime());
                const meetingSelect = document.getElementById('meeting-select') as HTMLSelectElement;
                meetingSelect.innerHTML = '<option value="">— Select race —</option>';
                meetingsData.forEach((meeting: any) => {
                    const option = document.createElement('option');
                    option.value = meeting.meeting_key;
                    option.textContent = meeting.meeting_name;
                    meetingSelect.appendChild(option);
                });
                (document.getElementById('session-select') as HTMLSelectElement).innerHTML = '<option value="">— Session —</option>';
                (document.getElementById('driver-select') as HTMLSelectElement).innerHTML = '<option value="">— All drivers —</option>';
                selectedSessionKey = null;
                selectedDriverNumber = null;
                (document.getElementById('fetch-button') as HTMLButtonElement).disabled = true;
                updateUrlDisplay();
            }

            async function loadSessions() {
                const meetingSelect = document.getElementById('meeting-select') as HTMLSelectElement;
                if (!meetingSelect.value) return;
                const sessionsData = await fetch(`${BASE_URL}/sessions?meeting_key=${meetingSelect.value}`).then(response => response.json());
                const sessionSelect = document.getElementById('session-select') as HTMLSelectElement;
                sessionSelect.innerHTML = '<option value="">— Session —</option>';
                sessionsData.forEach((session: any) => {
                    const option = document.createElement('option');
                    option.value = session.session_key;
                    option.textContent = session.session_name;
                    sessionSelect.appendChild(option);
                });
                selectedSessionKey = null;
                selectedDriverNumber = null;
                (document.getElementById('driver-select') as HTMLSelectElement).innerHTML = '<option value="">— All drivers —</option>';
                (document.getElementById('fetch-button') as HTMLButtonElement).disabled = true;
                updateUrlDisplay();
            }

            async function loadDrivers(sessionKey: string) {
                const driversData = await fetch(`${BASE_URL}/drivers?session_key=${sessionKey}`).then(response => response.json());
                driversData.sort((driverA: any, driverB: any) => driverA.driver_number - driverB.driver_number);
                const driverSelect = document.getElementById('driver-select') as HTMLSelectElement;
                driverSelect.innerHTML = '<option value="">— All drivers —</option>';
                driversData.forEach((driver: any) => {
                    const option = document.createElement('option');
                    option.value = driver.driver_number;
                    option.textContent = `${driver.name_acronym} — #${driver.driver_number} — ${driver.team_name}`;
                    driverSelect.appendChild(option);
                });
            }

            async function fetchJson() {
                const statusMessage = document.getElementById('status-message');
                const jsonOutput = document.getElementById('json-output');
                if (!statusMessage || !jsonOutput) return;
                statusMessage.textContent = 'Fetching...';
                jsonOutput.textContent = '// loading...';
                try {
                    const startTime = Date.now();
                    let responseData: any;

                    if (activeEndpointPath === '/overtakes' && selectedDriverNumber) {
                        responseData = await fetchAndMergeOvertakes();
                    } else {
                        responseData = await fetch(buildRequestUrl()).then(response => response.json());
                    }

                    jsonOutput.textContent = JSON.stringify(responseData, null, 2);
                    statusMessage.textContent = `${Array.isArray(responseData) ? responseData.length + ' records' : 'object'} · ${Date.now() - startTime}ms`;
                } catch (error: any) {
                    statusMessage.textContent = error.message;
                    jsonOutput.textContent = '// error: ' + error.message;
                }
            }

            function copyJson() {
                const jsonOutput = document.getElementById('json-output');
                if (jsonOutput) navigator.clipboard.writeText(jsonOutput.textContent ?? '').catch(() => {});
            }

            document.getElementById('year-select')?.addEventListener('change', loadMeetings);
            document.getElementById('meeting-select')?.addEventListener('change', loadSessions);

            document.getElementById('session-select')?.addEventListener('change', async function () {
                const sessionSelect = this as HTMLSelectElement;
                selectedSessionKey = sessionSelect.value || null;
                selectedDriverNumber = null;
                (document.getElementById('driver-select') as HTMLSelectElement).innerHTML = '<option value="">— All drivers —</option>';
                if (selectedSessionKey) {
                    await loadDrivers(selectedSessionKey);
                }
                updateUrlDisplay();
            });

            document.getElementById('driver-select')?.addEventListener('change', function () {
                const driverSelect = this as HTMLSelectElement;
                selectedDriverNumber = driverSelect.value || null;
                updateUrlDisplay();
            });

            document.getElementById('fetch-button')?.addEventListener('click', fetchJson);
            document.getElementById('copy-button')?.addEventListener('click', copyJson);

            loadMeetings();

            // ── Track Visualiser ──────────────────────────────────────────

            const scene = new THREE.Scene();
            scene.background = new THREE.Color(0x1a1a1a);

            const camera = new THREE.OrthographicCamera(-400, 400, 300, -300, 0.1, 1000);
            camera.position.set(0, 0, 100);
            camera.lookAt(0, 0, 0);

            const renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(800, 600);
            renderer.setPixelRatio(window.devicePixelRatio);

            document.getElementById('track-container')?.appendChild(renderer.domElement);

            renderer.render(scene, camera);
        </script>
    </body>
</html>