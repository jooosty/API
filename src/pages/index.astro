---
---
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title>F1 Explorer</title>
    </head>
    <body>
        <div id="app">
            <select id="year-select">
                <option value="2025">2025</option>
                <option value="2024">2024</option>
                <option value="2023">2023</option>
            </select>
            <select id="meeting-select"><option value="">— Select race —</option></select>
            <select id="session-select"><option value="">— Session —</option></select>
            <select id="driver-select"><option value="">— All drivers —</option></select>

            <div id="endpoint-buttons"></div>
            <div id="url-display"></div>

            <button id="fetch-button" disabled>Fetch JSON</button>
            <button id="copy-button">Copy</button>
            <span id="status-message"></span>

            <pre id="json-output">// JSON will appear here</pre>
        </div>

        <hr />

        <h2>Track Visualiser</h2>
        <div style="margin-bottom: 6px;">
            <button id="load-track-button">Load Track</button>
            <label for="speed-select">Speed:</label>
            <select id="speed-select">
                <option value="1">1x</option>
                <option value="2">2x</option>
                <option value="5">5x</option>
                <option value="10" selected>10x</option>
                <option value="25">25x</option>
                <option value="50">50x</option>
            </select>
            <button id="play-pause-button" disabled>Pause</button>
        </div>
        <div style="display: flex; gap: 12px; align-items: flex-start;">
            <div>
                <div id="track-container" style="width: 800px; height: 600px;"></div>
                <div style="width: 800px; display: flex; align-items: center; gap: 10px; margin-top: 6px;">
                    <span id="time-display" style="font-family: monospace; font-size: 13px; min-width: 50px;">0:00</span>
                    <input type="range" id="timeline-scrubber" min="0" max="1000" value="0" disabled style="flex: 1;" />
                    <span id="time-total" style="font-family: monospace; font-size: 13px; min-width: 50px;"></span>
                </div>
            </div>
            <div id="interval-tower" style="background: #111; color: #fff; width: 220px; min-height: 600px; font-family: monospace; font-size: 13px; padding: 8px 0; flex-shrink: 0;">
                <div style="text-align: center; font-size: 11px; color: #888; padding: 4px 8px 4px; letter-spacing: 0.08em; text-transform: uppercase;">Intervals</div>
                <div id="phase-indicator" style="text-align: center; font-size: 13px; font-weight: bold; padding: 4px 8px 8px; border-bottom: 1px solid #333; margin-bottom: 4px; letter-spacing: 0.1em;"></div>
                <div id="interval-rows" style="padding: 0 4px;">
                    <div style="color: #555; text-align: center; padding: 20px 0; font-size: 11px;">Load track to show</div>
                </div>
            </div>
        </div>

        <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
        <script>
            // ── JSON Explorer ─────────────────────────────────────────────

            const BASE_URL = 'https://api.openf1.org/v1';
            const ENDPOINTS = [
                { label: 'Drivers', path: '/drivers' },
                { label: 'Results', path: '/session_result' },
                { label: 'Laps', path: '/laps' },
                { label: 'Stints', path: '/stints' },
                { label: 'Pit Stops', path: '/pit' },
                { label: 'Position', path: '/position' },
                { label: 'Intervals', path: '/intervals' },
                { label: 'Race Control', path: '/race_control' },
                { label: 'Weather', path: '/weather' },
                { label: 'Starting Grid', path: '/starting_grid' },
                { label: 'Team Radio', path: '/team_radio' },
                { label: 'Overtakes', path: '/overtakes' },
                { label: 'Car Data', path: '/car_data' },
            ];

            const ENDPOINTS_WITHOUT_DRIVER_FILTER = [
                '/session_result',
                '/race_control',
                '/weather',
                '/starting_grid',
            ];

            let selectedSessionKey: string | null = null;
            let selectedDriverNumber: string | null = null;
            let activeEndpointPath: string = ENDPOINTS[0].path;

            const endpointButtonsContainer = document.getElementById('endpoint-buttons');
            ENDPOINTS.forEach(endpoint => {
                const button = document.createElement('button');
                button.textContent = endpoint.label;
                button.addEventListener('click', () => {
                    activeEndpointPath = endpoint.path;
                    updateUrlDisplay();
                });
                endpointButtonsContainer?.appendChild(button);
            });

            function buildRequestUrl() {
                let url = `${BASE_URL}${activeEndpointPath}?session_key=${selectedSessionKey}`;
                const driverFilterAllowed = !ENDPOINTS_WITHOUT_DRIVER_FILTER.includes(activeEndpointPath);
                if (selectedDriverNumber && driverFilterAllowed) {
                    if (activeEndpointPath === '/overtakes') {
                        url += `&overtaking_driver_number=${selectedDriverNumber}&overtaken_driver_number=${selectedDriverNumber}`;
                    } else {
                        url += `&driver_number=${selectedDriverNumber}`;
                    }
                }
                return url;
            }

            async function fetchAndMergeOvertakes(): Promise<any[]> {
                const overtakingUrl = `${BASE_URL}/overtakes?session_key=${selectedSessionKey}&overtaking_driver_number=${selectedDriverNumber}`;
                const overtakenUrl = `${BASE_URL}/overtakes?session_key=${selectedSessionKey}&overtaken_driver_number=${selectedDriverNumber}`;

                const [overtakingResults, overtakenResults] = await Promise.all([
                    fetch(overtakingUrl).then(response => response.json()),
                    fetch(overtakenUrl).then(response => response.json()),
                ]);

                const mergedResults = [...overtakingResults, ...overtakenResults];
                mergedResults.sort((entryA: any, entryB: any) => new Date(entryA.date).getTime() - new Date(entryB.date).getTime());
                return mergedResults;
            }

            function updateUrlDisplay() {
                const urlDisplay = document.getElementById('url-display');
                if (!selectedSessionKey || !urlDisplay) return;

                if (activeEndpointPath === '/overtakes' && selectedDriverNumber) {
                    urlDisplay.textContent = `${BASE_URL}/overtakes?session_key=${selectedSessionKey}&overtaking_driver_number=${selectedDriverNumber} + overtaken_driver_number=${selectedDriverNumber} (merged)`;
                } else {
                    urlDisplay.textContent = buildRequestUrl();
                }

                (document.getElementById('fetch-button') as HTMLButtonElement).disabled = false;
            }

            async function loadMeetings() {
                const selectedYear = (document.getElementById('year-select') as HTMLSelectElement).value;
                const meetingsData = await fetch(`${BASE_URL}/meetings?year=${selectedYear}`).then(response => response.json());
                meetingsData.sort((meetingA: any, meetingB: any) => new Date(meetingA.date_start).getTime() - new Date(meetingB.date_start).getTime());
                const meetingSelect = document.getElementById('meeting-select') as HTMLSelectElement;
                meetingSelect.innerHTML = '<option value="">— Select race —</option>';
                meetingsData.forEach((meeting: any) => {
                    const option = document.createElement('option');
                    option.value = meeting.meeting_key;
                    option.textContent = meeting.meeting_name;
                    meetingSelect.appendChild(option);
                });
                (document.getElementById('session-select') as HTMLSelectElement).innerHTML = '<option value="">— Session —</option>';
                (document.getElementById('driver-select') as HTMLSelectElement).innerHTML = '<option value="">— All drivers —</option>';
                selectedSessionKey = null;
                selectedDriverNumber = null;
                (document.getElementById('fetch-button') as HTMLButtonElement).disabled = true;
                updateUrlDisplay();
            }

            async function loadSessions() {
                const meetingSelect = document.getElementById('meeting-select') as HTMLSelectElement;
                if (!meetingSelect.value) return;
                const sessionsData = await fetch(`${BASE_URL}/sessions?meeting_key=${meetingSelect.value}`).then(response => response.json());
                const sessionSelect = document.getElementById('session-select') as HTMLSelectElement;
                sessionSelect.innerHTML = '<option value="">— Session —</option>';
                sessionsData.forEach((session: any) => {
                    const option = document.createElement('option');
                    option.value = session.session_key;
                    option.textContent = session.session_name;
                    sessionSelect.appendChild(option);
                });
                selectedSessionKey = null;
                selectedDriverNumber = null;
                (document.getElementById('driver-select') as HTMLSelectElement).innerHTML = '<option value="">— All drivers —</option>';
                (document.getElementById('fetch-button') as HTMLButtonElement).disabled = true;
                updateUrlDisplay();
            }

            async function loadDrivers(sessionKey: string) {
                const driversData = await fetch(`${BASE_URL}/drivers?session_key=${sessionKey}`).then(response => response.json());
                driversData.sort((driverA: any, driverB: any) => driverA.driver_number - driverB.driver_number);
                const driverSelect = document.getElementById('driver-select') as HTMLSelectElement;
                driverSelect.innerHTML = '<option value="">— All drivers —</option>';
                driversData.forEach((driver: any) => {
                    const option = document.createElement('option');
                    option.value = driver.driver_number;
                    option.textContent = `${driver.name_acronym} — #${driver.driver_number} — ${driver.team_name}`;
                    driverSelect.appendChild(option);
                });
            }

            async function fetchJson() {
                const statusMessage = document.getElementById('status-message');
                const jsonOutput = document.getElementById('json-output');
                if (!statusMessage || !jsonOutput) return;
                statusMessage.textContent = 'Fetching...';
                jsonOutput.textContent = '// loading...';
                try {
                    const startTime = Date.now();
                    let responseData: any;

                    if (activeEndpointPath === '/overtakes' && selectedDriverNumber) {
                        responseData = await fetchAndMergeOvertakes();
                    } else {
                        responseData = await fetch(buildRequestUrl()).then(response => response.json());
                    }

                    jsonOutput.textContent = JSON.stringify(responseData, null, 2);
                    statusMessage.textContent = `${Array.isArray(responseData) ? responseData.length + ' records' : 'object'} · ${Date.now() - startTime}ms`;
                } catch (error: any) {
                    statusMessage.textContent = error.message;
                    jsonOutput.textContent = '// error: ' + error.message;
                }
            }

            function copyJson() {
                const jsonOutput = document.getElementById('json-output');
                if (jsonOutput) navigator.clipboard.writeText(jsonOutput.textContent ?? '').catch(() => {});
            }

            document.getElementById('year-select')?.addEventListener('change', loadMeetings);
            document.getElementById('meeting-select')?.addEventListener('change', loadSessions);

            document.getElementById('session-select')?.addEventListener('change', async function () {
                const sessionSelect = this as HTMLSelectElement;
                selectedSessionKey = sessionSelect.value || null;
                selectedDriverNumber = null;
                (document.getElementById('driver-select') as HTMLSelectElement).innerHTML = '<option value="">— All drivers —</option>';
                if (selectedSessionKey) {
                    await loadDrivers(selectedSessionKey);
                }
                updateUrlDisplay();
            });

            document.getElementById('driver-select')?.addEventListener('change', function () {
                const driverSelect = this as HTMLSelectElement;
                selectedDriverNumber = driverSelect.value || null;
                updateUrlDisplay();
            });

            document.getElementById('fetch-button')?.addEventListener('click', fetchJson);
            document.getElementById('copy-button')?.addEventListener('click', copyJson);

            loadMeetings();

            // ── Track Visualiser ──────────────────────────────────────────

            const scene = new THREE.Scene();
            scene.background = new THREE.Color(0x1a1a1a);

            const camera = new THREE.OrthographicCamera(-400, 400, 300, -300, 0.1, 1000);
            camera.position.set(0, 0, 100);
            camera.lookAt(0, 0, 0);

            const renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(800, 600);
            renderer.setPixelRatio(window.devicePixelRatio);

            document.getElementById('track-container')?.appendChild(renderer.domElement);

            async function loadTrack() {
                const sessionKey = selectedSessionKey;
                if (!sessionKey) {
                    alert('Please select a session first.');
                    return;
                }

                function delay(ms: number): Promise<void> {
                    return new Promise(resolve => setTimeout(resolve, ms));
                }

                // loading label shown on the canvas while fetching
                const loadingCanvas = document.createElement('canvas');
                loadingCanvas.width = 512;
                loadingCanvas.height = 64;
                const loadingContext = loadingCanvas.getContext('2d') as CanvasRenderingContext2D;

                const loadingTexture = new THREE.CanvasTexture(loadingCanvas);
                const loadingMaterial = new THREE.SpriteMaterial({ map: loadingTexture });
                const loadingSprite = new THREE.Sprite(loadingMaterial);
                loadingSprite.scale.set(400, 50, 1);
                loadingSprite.position.set(0, 0, 1);
                scene.add(loadingSprite);

                function setLoadingText(text: string): void {
                    loadingContext.clearRect(0, 0, loadingCanvas.width, loadingCanvas.height);
                    loadingContext.fillStyle = '#ffffff';
                    loadingContext.font = 'bold 48px monospace';
                    loadingContext.textAlign = 'center';
                    loadingContext.fillText(text, loadingCanvas.width / 2, 52);
                    loadingTexture.needsUpdate = true;
                    renderer.render(scene, camera);
                }

                setLoadingText('Fetching session...');

                // clear any previously loaded track and dots
                scene.clear();
                scene.background = new THREE.Color(0x1a1a1a);
                scene.add(loadingSprite);
                renderer.render(scene, camera);

                // fetch session date range
                const sessionData = await fetch(
                    `${BASE_URL}/sessions?session_key=${sessionKey}`
                ).then(r => r.json());


                await delay(500);

                setLoadingText('Fetching drivers...');

                // fetch all drivers in the session
                const driversData = await fetch(
                    `${BASE_URL}/drivers?session_key=${sessionKey}`
                ).then(r => r.json());

                // detect session type to decide what tower data to fetch
                const sessionType: string = (sessionData[0].session_type || '').toLowerCase();
                const isQualifying: boolean = sessionType.includes('qualifying');

                // fetch tower data depending on session type
                let allIntervalData: any[] = [];
                let allPositionData: any[] = [];
                let allLapData: any[] = [];
                let qualPhaseBoundaries: number[] = [];
                const dnfDrivers: Set<number> = new Set();

                if (isQualifying) {
                    setLoadingText('Fetching lap times...');
                    const lapRaw = await fetch(`${BASE_URL}/laps?session_key=${sessionKey}`).then(r => r.json());
                    allLapData = Array.isArray(lapRaw) ? lapRaw : [];
                    await delay(400);

                    // Use race control events to detect Q phase boundaries.
                    // Events with qualifying_phase set tell us exactly when each phase is active.
                    setLoadingText('Fetching race control...');
                    const rcRaw = await fetch(`${BASE_URL}/race_control?session_key=${sessionKey}`).then(r => r.json());
                    const rcData: any[] = Array.isArray(rcRaw) ? rcRaw : [];
                    await delay(400);

                    // Find the start time of each qualifying phase from race control events
                    // qualifying_phase is 1, 2, or 3 — find first event per phase
                    const phaseStartTimes: Record<number, number> = {};
                    for (const event of rcData) {
                        if (!event.qualifying_phase || !event.date) continue;
                        const phase = Number(event.qualifying_phase);
                        const t = new Date(event.date).getTime();
                        if (!phaseStartTimes[phase] || t < phaseStartTimes[phase]) {
                            phaseStartTimes[phase] = t;
                        }
                    }

                    // Boundary is exactly the start of the next phase
                    qualPhaseBoundaries = [];
                    for (let p = 1; p <= 2; p++) {
                        const nextPhaseStart = phaseStartTimes[p + 1];
                        if (nextPhaseStart) {
                            qualPhaseBoundaries.push(nextPhaseStart);
                        }
                    }

                    console.log('[QUALI INIT] phase starts:', phaseStartTimes, '| boundaries:', qualPhaseBoundaries.map(b => new Date(b).toISOString()));
                } else {
                    setLoadingText('Fetching intervals...');
                    const ivRaw = await fetch(`${BASE_URL}/intervals?session_key=${sessionKey}`).then(r => r.json());
                    allIntervalData = Array.isArray(ivRaw) ? ivRaw : [];
                    await delay(400);
                    setLoadingText('Fetching positions...');
                    const posRaw = await fetch(`${BASE_URL}/position?session_key=${sessionKey}`).then(r => r.json());
                    allPositionData = Array.isArray(posRaw) ? posRaw : [];
                    await delay(400);
                    setLoadingText('Fetching results...');
                    const sessionResultRaw: any = await fetch(`${BASE_URL}/session_result?session_key=${sessionKey}`).then(r => r.json());
                    const sessionResultData: any[] = Array.isArray(sessionResultRaw) ? sessionResultRaw : [];
                    await delay(400);
                    sessionResultData.filter((r: any) => r.dnf || r.dns || r.dsq).forEach((r: any) => dnfDrivers.add(r.driver_number));
                }
                // build a driver acronym/colour lookup from driversData
                const driverInfoMap: Record<number, { acronym: string; colour: string }> = {};
                driversData.forEach((d: any) => {
                    driverInfoMap[d.driver_number] = {
                        acronym: d.name_acronym || ('#' + d.driver_number),
                        colour: d.team_colour ? '#' + d.team_colour : '#ffffff',
                    };
                });

                // wait 1 second after fetching drivers before starting location requests
                await delay(1000);

                // fetch location data for each driver sequentially to respect rate limit
                // 500ms between requests = 2 per second, well under the 3/sec limit
                const allDriverLocationData: { driver: any; points: any[] }[] = [];
                for (const driver of driversData) {
                    setLoadingText(`Loading ${driver.name_acronym} (${allDriverLocationData.length + 1}/${driversData.length})`);
                    const points = await fetch(
                        `${BASE_URL}/location?session_key=${sessionKey}&driver_number=${driver.driver_number}&date>=${new Date(sessionData[0].date_start).toISOString()}`
                    ).then(r => r.json());
                    if (points.length > 0) {
                        allDriverLocationData.push({ driver, points });
                    }
                    await delay(500);
                }

                // remove loading sprite once done
                scene.remove(loadingSprite);

                // combine all points to compute a shared center and scale
                const allPoints = allDriverLocationData.flatMap(d => d.points);

                const minX = allPoints.reduce((min: number, p: any) => p.x < min ? p.x : min, Infinity);
                const maxX = allPoints.reduce((max: number, p: any) => p.x > max ? p.x : max, -Infinity);
                const minY = allPoints.reduce((min: number, p: any) => p.y < min ? p.y : min, Infinity);
                const maxY = allPoints.reduce((max: number, p: any) => p.y > max ? p.y : max, -Infinity);

                const centerX = (minX + maxX) / 2;
                const centerY = (minY + maxY) / 2;

                const trackWidth = (maxX - minX) * 0.1;
                const trackHeight = (maxY - minY) * 0.1;
                const scale = Math.min(700 / trackWidth, 500 / trackHeight) * 0.9;

                function toTrackPoint(point: any): any {
                    return new THREE.Vector3(
                        (point.x - centerX) * 0.1 * scale,
                        (point.y - centerY) * 0.1 * scale,
                        0
                    );
                }

                // draw track line from the driver with the most points
                const mostPoints = allDriverLocationData.reduce((best, current) =>
                    current.points.length > best.points.length ? current : best
                );
                const trackLinePoints = mostPoints.points.map(toTrackPoint);
                const trackGeometry = new THREE.BufferGeometry().setFromPoints(trackLinePoints);
                const trackMaterial = new THREE.LineBasicMaterial({ color: 0x444444 });
                const trackLine = new THREE.Line(trackGeometry, trackMaterial);
                scene.add(trackLine);

                // create a dot and mapped points array for each driver
                const driverDots = allDriverLocationData.map(({ driver, points }) => {
                    const teamColor = driver.team_colour ? parseInt(driver.team_colour, 16) : 0xffffff;
                    const dotMesh = new THREE.Mesh(
                        new THREE.CircleGeometry(5, 32),
                        new THREE.MeshBasicMaterial({ color: teamColor })
                    );
                    const mappedPoints = points.map(toTrackPoint);
                    dotMesh.position.set(mappedPoints[0].x, mappedPoints[0].y, 1);
                    scene.add(dotMesh);
                    return { dotMesh, mappedPoints, rawPoints: points, index: 0 };
                });

                let zoomLevel: number = 1;
                let isPanning: boolean = false;
                let panStartX: number = 0;
                let panStartY: number = 0;
                let cameraOffsetX: number = 0;
                let cameraOffsetY: number = 0;

                function updateCamera(): void {
                    const baseWidth = 400;
                    const baseHeight = 300;
                    camera.left = -baseWidth / zoomLevel + cameraOffsetX;
                    camera.right = baseWidth / zoomLevel + cameraOffsetX;
                    camera.top = baseHeight / zoomLevel + cameraOffsetY;
                    camera.bottom = -baseHeight / zoomLevel + cameraOffsetY;
                    camera.updateProjectionMatrix();
                    renderer.render(scene, camera);
                }

                renderer.domElement.addEventListener('wheel', (wheelEvent: WheelEvent) => {
                    wheelEvent.preventDefault();
                    zoomLevel *= wheelEvent.deltaY < 0 ? 1.1 : 0.9;
                    zoomLevel = Math.max(0.5, Math.min(20, zoomLevel));
                    updateCamera();
                });

                renderer.domElement.addEventListener('mousedown', (mouseEvent: MouseEvent) => {
                    isPanning = true;
                    panStartX = mouseEvent.clientX;
                    panStartY = mouseEvent.clientY;
                });

                renderer.domElement.addEventListener('mousemove', (mouseEvent: MouseEvent) => {
                    if (!isPanning) return;
                    const deltaX = (mouseEvent.clientX - panStartX) / zoomLevel;
                    const deltaY = (mouseEvent.clientY - panStartY) / zoomLevel;
                    panStartX = mouseEvent.clientX;
                    panStartY = mouseEvent.clientY;
                    cameraOffsetX -= deltaX;
                    cameraOffsetY += deltaY;
                    updateCamera();
                });

                renderer.domElement.addEventListener('mouseup', () => { isPanning = false; });
                renderer.domElement.addEventListener('mouseleave', () => { isPanning = false; });

                let lastRealTime: number | null = null;
                const firstLocationTime: number = Math.min(
                    ...allDriverLocationData.map(d => new Date(d.points[0].date).getTime())
                );
                const firstLapTime: number = allLapData.length > 0
                    ? Math.min(...allLapData.filter((l: any) => l.date_start).map((l: any) => new Date(l.date_start).getTime()))
                    : Infinity;
                // Start 1 minute before the first lap begins so the out-lap is visible.
                // Fall back to first location point if no lap data available.
                const earliestTime: number = firstLapTime < Infinity
                    ? Math.max(firstLocationTime, firstLapTime - 60 * 1000)
                    : firstLocationTime;
                const latestTime: number = Math.max(
                    ...allDriverLocationData.map(d => new Date(d.points[d.points.length - 1].date).getTime())
                );
                const totalDuration: number = latestTime - earliestTime;
                let simulatedTime: number = earliestTime;
                let isPlaying: boolean = true;
                let isScrubbing: boolean = false;

                const timelineScrubber = document.getElementById('timeline-scrubber') as HTMLInputElement;
                const timeDisplay = document.getElementById('time-display') as HTMLElement;
                const timeTotal = document.getElementById('time-total') as HTMLElement;

                timelineScrubber.disabled = false;
                timeTotal.textContent = formatTime(totalDuration);

                function formatTime(ms: number): string {
                    const totalSeconds = Math.floor(ms / 1000);
                    const hours = Math.floor(totalSeconds / 3600);
                    const minutes = Math.floor((totalSeconds % 3600) / 60);
                    const seconds = totalSeconds % 60;
                    if (hours > 0) {
                        return `${hours}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
                    }
                    return `${minutes}:${String(seconds).padStart(2, '0')}`;
                }

                // ── Qualifying Tower ──────────────────────────────────────
                function updateQualifyingTower(currentSimTime: number, intervalRows: HTMLElement): void {
                    // build best lap per driver using only laps completed before currentSimTime
                    const bestLap: Record<number, number> = {};
                    const lastLapTime: Record<number, number> = {}; // last lap start time per driver
                    for (const lap of allLapData) {
                        if (!lap.date_start || !lap.lap_duration) continue;
                        const lapStart = new Date(lap.date_start).getTime();
                        const lapEnd = lapStart + lap.lap_duration * 1000;
                        if (lapEnd > currentSimTime) continue;
                        const dn = lap.driver_number;
                        if (!bestLap[dn] || lap.lap_duration < bestLap[dn]) {
                            bestLap[dn] = lap.lap_duration;
                        }
                        if (!lastLapTime[dn] || lapStart > lastLapTime[dn]) {
                            lastLapTime[dn] = lapStart;
                        }
                    }

                    const driverNums = Object.keys(bestLap).map(Number);
                    if (driverNums.length === 0) {
                        intervalRows.innerHTML = '<div style="color:#555;text-align:center;padding:20px 0;font-size:11px;">No lap times yet</div>';
                        return;
                    }

                    driverNums.sort((a, b) => bestLap[a] - bestLap[b]);

                    // Use pre-computed stable phase boundaries from load time
                    const phaseBoundaries = qualPhaseBoundaries;

                    // Determine which phase we're currently in (0 = Q1, 1 = Q2, 2 = Q3)
                    let currentPhase = 0;
                    for (const boundary of phaseBoundaries) {
                        if (currentSimTime > boundary) currentPhase++;
                    }

                    // Update phase indicator in tower header
                    const phaseIndicator = document.getElementById('phase-indicator');
                    if (phaseIndicator) {
                        const phaseNames = ['Q1', 'Q2', 'Q3'];
                        const phaseColors = ['#4a9eff', '#ff9f1a', '#cc44ff'];
                        const clampedPhase = Math.min(currentPhase, 2);
                        const phaseName = phaseNames[clampedPhase];
                        const phaseColor = phaseColors[clampedPhase];
                        // phase has ended if the next boundary exists and sim time is past it
                        // i.e. we are now in a later phase than this one
                        const isLastPhase = currentPhase >= phaseBoundaries.length;
                        phaseIndicator.textContent = !isLastPhase && currentPhase > clampedPhase ? `${phaseName} — ENDED` : phaseName;
                        phaseIndicator.style.color = phaseColor;
                        phaseIndicator.style.opacity = '1';
                    }

                    // Phase time window
                    const phaseStart = currentPhase === 0 ? 0 : phaseBoundaries[currentPhase - 1];
                    const phaseEnd = currentPhase < phaseBoundaries.length ? phaseBoundaries[currentPhase] : Infinity;

                    // Best lap set in the current phase (or any phase up to now for ranking)
                    // Use date_start to place lap in a phase (lap_duration can be null)
                    const bestLapCurrentPhase: Record<number, number> = {};
                    for (const lap of allLapData) {
                        if (!lap.date_start || !lap.lap_duration) continue;
                        const lapStart = new Date(lap.date_start).getTime();
                        const lapEnd = lapStart + lap.lap_duration * 1000;
                        if (lapEnd > currentSimTime) continue;
                        if (lapStart <= phaseStart || lapStart > phaseEnd) continue;
                        const dn = lap.driver_number;
                        if (!bestLapCurrentPhase[dn] || lap.lap_duration < bestLapCurrentPhase[dn]) {
                            bestLapCurrentPhase[dn] = lap.lap_duration;
                        }
                    }

                    // Who has set a lap in the current phase
                    const activeThisPhase = new Set(Object.keys(bestLapCurrentPhase).map(Number));

                    // Drivers eliminated in previous phases: had a lap before but NOT in the current phase
                    // (only applies if we're past Q1 boundary)
                    const eliminatedFromPrevPhase: Set<number> = new Set();
                    if (currentPhase > 0) {
                        for (const dn of driverNums) {
                            if (!activeThisPhase.has(dn)) {
                                eliminatedFromPrevPhase.add(dn);
                            }
                        }
                    }

                    // Advance counts: Q1->15, Q2->10, Q3->no elimination
                    const advanceCounts = [15, 10, 999];
                    const advanceCount = advanceCounts[Math.min(currentPhase, 2)];

                    // Within the current phase, who is in the danger zone (live, session still running)
                    // Sort drivers who set a lap this phase by their time
                    const thisPhaseDrivers = [...activeThisPhase].sort((a, b) => bestLapCurrentPhase[a] - bestLapCurrentPhase[b]);
                    const eliminatedThisPhase: Set<number> = new Set();

                    // Check if we're past phase end (i.e. at least one phase boundary has passed since phaseStart)
                    const phaseEnded = phaseBoundaries.length > currentPhase;
                    if (phaseEnded && advanceCount < 999 && thisPhaseDrivers.length > advanceCount) {
                        thisPhaseDrivers.slice(advanceCount).forEach(dn => eliminatedThisPhase.add(dn));
                    }

                    // Build display: active (not eliminated) first, then eliminated from this phase, then prev phase
                    const sortedActive = thisPhaseDrivers.slice(0, phaseEnded ? advanceCount : undefined);
                    const sortedElimThisPhase = [...eliminatedThisPhase].sort((a, b) => (bestLapCurrentPhase[a] || 0) - (bestLapCurrentPhase[b] || 0));
                    const sortedElimPrev = [...eliminatedFromPrevPhase].sort((a, b) => (bestLap[a] || 0) - (bestLap[b] || 0));

                    // Drivers with no lap this phase but also not eliminated (no lap yet)
                    const noLapYet = driverNums.filter(dn => !activeThisPhase.has(dn) && !eliminatedFromPrevPhase.has(dn));

                    const orderedDriverNums = [...sortedActive, ...noLapYet, ...sortedElimThisPhase, ...sortedElimPrev];

                    // Live danger zone: bottom of current phase drivers who are at risk
                    const liveEliminationStart = (!phaseEnded && advanceCount < 999) ? advanceCount : -1;

                    const poleLap = bestLapCurrentPhase[sortedActive[0]] ?? bestLap[driverNums[0]];

                    intervalRows.innerHTML = '';
                    orderedDriverNums.forEach((dn, i) => {
                        const info = driverInfoMap[dn] || { acronym: '#' + dn, colour: '#fff' };
                        const isPole = i === 0;
                        const isElimPrev = eliminatedFromPrevPhase.has(dn);
                        const isElimThis = eliminatedThisPhase.has(dn);
                        const isEliminated = isElimPrev || isElimThis;
                        // live danger: in current phase, ranked beyond advanceCount
                        const liveRankInPhase = thisPhaseDrivers.indexOf(dn);
                        const isInDanger = !phaseEnded && liveRankInPhase >= advanceCount;

                        const lapSec = bestLapCurrentPhase[dn] ?? bestLap[dn];
                        const mins = Math.floor(lapSec / 60);
                        const secs = (lapSec % 60).toFixed(3).padStart(6, '0');
                        const lapTimeStr = `${mins}:${secs}`;
                        const deltaStr = isPole ? lapTimeStr : '+' + (lapSec - poleLap).toFixed(3);

                        const showRed = isEliminated || isInDanger;

                        const rowEl = document.createElement('div');
                        rowEl.style.cssText = `display:flex;align-items:center;gap:6px;padding:4px 6px;border-bottom:1px solid ${showRed ? '#3a1010' : '#1e1e1e'};${showRed ? 'background:#1a0a0a;' : ''}`;

                        const posEl = document.createElement('span');
                        posEl.style.cssText = `color:${showRed ? '#7a2020' : '#666'};font-size:11px;min-width:16px;text-align:right;`;
                        posEl.textContent = String(i + 1);

                        const dot = document.createElement('span');
                        dot.style.cssText = `display:inline-block;width:7px;height:7px;border-radius:50%;background:${info.colour};flex-shrink:0;`;

                        const acronym = document.createElement('span');
                        acronym.style.cssText = `font-weight:bold;font-size:12px;min-width:34px;letter-spacing:0.04em;color:${showRed ? '#e03030' : '#fff'};`;
                        acronym.textContent = info.acronym;

                        const rightCol = document.createElement('div');
                        rightCol.style.cssText = 'margin-left:auto;text-align:right;display:flex;flex-direction:column;gap:1px;';

                        const timeEl = document.createElement('span');
                        timeEl.style.cssText = `font-size:11px;color:${isPole ? '#f0c040' : showRed ? '#e03030' : '#ccc'};`;
                        timeEl.textContent = isElimPrev ? 'OUT' : deltaStr;

                        const lapEl = document.createElement('span');
                        lapEl.style.cssText = `font-size:10px;color:${showRed ? '#7a2020' : '#555'};`;
                        lapEl.textContent = (isPole || isElimPrev) ? '' : lapTimeStr;

                        rightCol.appendChild(timeEl);
                        rightCol.appendChild(lapEl);

                        rowEl.appendChild(posEl);
                        rowEl.appendChild(dot);
                        rowEl.appendChild(acronym);
                        rowEl.appendChild(rightCol);
                        intervalRows.appendChild(rowEl);
                    });
    
                }

                // ── Interval Tower ────────────────────────────────────────
                function updateIntervalTower(currentSimTime: number): void {
                    const intervalRows = document.getElementById('interval-rows');
                    if (!intervalRows) return;

                    if (isQualifying) {
                        updateQualifyingTower(currentSimTime, intervalRows);
                        return;
                    }

                    // Race session — clear phase indicator
                    const racePhaseEl = document.getElementById('phase-indicator');
                    if (racePhaseEl) racePhaseEl.textContent = '';

                    if (allIntervalData.length === 0) return;

                    // get latest interval entry per driver at or before currentSimTime
                    const latestInterval: Record<number, any> = {};
                    for (const entry of allIntervalData) {
                        const t = new Date(entry.date).getTime();
                        if (t > currentSimTime) continue;
                        const dn = entry.driver_number;
                        if (!latestInterval[dn] || t > new Date(latestInterval[dn].date).getTime()) {
                            latestInterval[dn] = entry;
                        }
                    }

                    // get latest position entry per driver at or before currentSimTime
                    const latestPosition: Record<number, any> = {};
                    for (const entry of allPositionData) {
                        const t = new Date(entry.date).getTime();
                        if (t > currentSimTime) continue;
                        const dn = entry.driver_number;
                        if (!latestPosition[dn] || t > new Date(latestPosition[dn].date).getTime()) {
                            latestPosition[dn] = entry;
                        }
                    }

                    const driverNums = Object.keys(latestInterval).map(Number);
                    if (driverNums.length === 0) return;

                    // sort by official position from position data, fall back to gap_to_leader
                    driverNums.sort((a, b) => {
                        const posA = latestPosition[a]?.position ?? 999;
                        const posB = latestPosition[b]?.position ?? 999;
                        if (posA !== posB) return posA - posB;
                        return (latestInterval[a]?.gap_to_leader ?? Infinity) - (latestInterval[b]?.gap_to_leader ?? Infinity);
                    });

                    // figure out lap count per driver from position data to detect lapped cars
                    // gap_to_leader > 120s almost certainly means lapped — use a lap-boundary heuristic
                    // We derive laps down from the leader's gap relative to a typical lap time estimate
                    // Simpler: if gap_to_leader for driver at pos N is MORE than gap_to_leader at pos N-1
                    // by more than ~60s, treat the difference as a lap marker
                    const leaderDn = driverNums[0];
                    const leaderGap = latestInterval[leaderDn]?.gap_to_leader ?? 0;

                    intervalRows.innerHTML = '';
                    driverNums.forEach((dn, i) => {
                        const intervalEntry = latestInterval[dn];
                        const info = driverInfoMap[dn] || { acronym: '#' + dn, colour: '#fff' };
                        const isLeader = i === 0;

                        const gapRaw = intervalEntry?.gap_to_leader;
                        const ivlRaw = intervalEntry?.interval;
                        const isLapped = typeof gapRaw === 'string' || typeof ivlRaw === 'string';



                        // detect retirement: DNF from session result, or interval data
                        // went stale (last update > 3 minutes behind current sim time)
                        const isRetired = dnfDrivers.has(dn) && (() => {
                            // only show RET once their data has actually stopped — i.e. their
                            // last interval timestamp is more than 3 min behind sim time
                            if (!intervalEntry) return true;
                            const lastUpdate = new Date(intervalEntry.date).getTime();
                            return (currentSimTime - lastUpdate) > 3 * 60 * 1000;
                        })();

                        // format interval (gap to car ahead)
                        let intervalText: string;
                        if (isLeader) {
                            intervalText = 'LEADER';
                        } else if (isRetired) {
                            intervalText = 'RET';
                        } else if (typeof ivlRaw === 'string') {
                            intervalText = ivlRaw;
                        } else if (typeof ivlRaw === 'number') {
                            intervalText = '+' + ivlRaw.toFixed(3);
                        } else {
                            intervalText = '—';
                        }

                        // format gap to leader
                        let gapText: string;
                        if (isLeader) {
                            gapText = '';
                        } else if (isRetired) {
                            gapText = '';
                        } else if (typeof gapRaw === 'string') {
                            gapText = gapRaw;
                        } else if (typeof gapRaw === 'number') {
                            gapText = '+' + gapRaw.toFixed(3);
                        } else {
                            gapText = '—';
                        }

                        const rowEl = document.createElement('div');
                        rowEl.style.cssText = 'display:flex;align-items:center;gap:6px;padding:4px 6px;border-bottom:1px solid #1e1e1e;';

                        const posEl = document.createElement('span');
                        posEl.style.cssText = 'color:#666;font-size:11px;min-width:16px;text-align:right;';
                        posEl.textContent = String(i + 1);

                        const dot = document.createElement('span');
                        dot.style.cssText = `display:inline-block;width:7px;height:7px;border-radius:50%;background:${info.colour};flex-shrink:0;`;

                        const acronym = document.createElement('span');
                        acronym.style.cssText = 'font-weight:bold;font-size:12px;min-width:34px;letter-spacing:0.04em;';
                        acronym.textContent = info.acronym;

                        const rightCol = document.createElement('div');
                        rightCol.style.cssText = 'margin-left:auto;text-align:right;display:flex;flex-direction:column;gap:1px;';

                        const intervalEl = document.createElement('span');
                        
                        intervalEl.style.cssText = `font-size:11px;color:${isLeader ? '#f0c040' : isRetired ? '#666' : '#ccc'};`;
                        intervalEl.textContent = intervalText;

                        const gapEl = document.createElement('span');
                        gapEl.style.cssText = `font-size:10px;color:#555;`;
                        gapEl.textContent = gapText;

                        rightCol.appendChild(intervalEl);
                        if (!isLeader) rightCol.appendChild(gapEl);

                        rowEl.appendChild(posEl);
                        rowEl.appendChild(dot);
                        rowEl.appendChild(acronym);
                        rowEl.appendChild(rightCol);
                        intervalRows.appendChild(rowEl);
                    });
                }

                const STATIONARY_HIDE_MS = 2 * 60 * 1000; // 2 minutes
                const STATIONARY_MOVE_THRESHOLD = 5; // raw coordinate units — below this counts as "not moved"

                // Returns true if the driver has not meaningfully moved in the last STATIONARY_HIDE_MS
                function isDriverStationary(driverDot: any, currentIndex: number): boolean {
                    const currentRaw = driverDot.rawPoints[currentIndex];
                    const cutoffTime = new Date(currentRaw.date).getTime() - STATIONARY_HIDE_MS;
                    // Walk backwards to find the point at the cutoff time
                    let lookbackIndex = currentIndex;
                    while (lookbackIndex > 0 && new Date(driverDot.rawPoints[lookbackIndex].date).getTime() > cutoffTime) {
                        lookbackIndex--;
                    }
                    const pastRaw = driverDot.rawPoints[lookbackIndex];
                    const dx = currentRaw.x - pastRaw.x;
                    const dy = currentRaw.y - pastRaw.y;
                    return Math.sqrt(dx * dx + dy * dy) < STATIONARY_MOVE_THRESHOLD;
                }

                function updateAllDriversToTime(targetTime: number): void {
                    for (const driverDot of driverDots) {
                        // reset index if we scrubbed backwards
                        if (new Date(driverDot.rawPoints[driverDot.index].date).getTime() > targetTime) {
                            driverDot.index = 0;
                        }
                        while (
                            driverDot.index < driverDot.rawPoints.length - 1 &&
                            new Date(driverDot.rawPoints[driverDot.index + 1].date).getTime() < targetTime
                        ) {
                            driverDot.index++;
                        }
                        const currentPoint = driverDot.mappedPoints[driverDot.index];
                        driverDot.dotMesh.position.set(currentPoint.x, currentPoint.y, 1);
                        driverDot.dotMesh.visible = !isDriverStationary(driverDot, driverDot.index);
                    }
                    const elapsed = targetTime - earliestTime;
                    timeDisplay.textContent = formatTime(elapsed);
                    timelineScrubber.value = String(Math.round((elapsed / totalDuration) * 1000));
                    updateIntervalTower(targetTime);
                    renderer.render(scene, camera);
                }

                timelineScrubber.addEventListener('mousedown', () => {
                    isScrubbing = true;
                    isPlaying = false;
                    lastRealTime = null;
                    (document.getElementById('play-pause-button') as HTMLButtonElement).textContent = 'Play';
                });

                timelineScrubber.addEventListener('input', () => {
                    const fraction = Number(timelineScrubber.value) / 1000;
                    simulatedTime = earliestTime + fraction * totalDuration;
                    updateAllDriversToTime(simulatedTime);
                });

                timelineScrubber.addEventListener('mouseup', () => {
                    isScrubbing = false;
                });

                function animate(realTimestamp: number): void {
                    requestAnimationFrame(animate);

                    if (!isPlaying || isScrubbing) return;

                    if (lastRealTime === null) lastRealTime = realTimestamp;
                    const realElapsed = realTimestamp - lastRealTime;
                    lastRealTime = realTimestamp;

                    const speedMultiplier = Number((document.getElementById('speed-select') as HTMLSelectElement).value);
                    simulatedTime += realElapsed * speedMultiplier;

                    let reachedEnd = true; // assume done unless a driver still has points ahead

                    for (const driverDot of driverDots) {
                        while (
                            driverDot.index < driverDot.rawPoints.length - 1 &&
                            new Date(driverDot.rawPoints[driverDot.index + 1].date).getTime() < simulatedTime
                        ) {
                            driverDot.index++;
                        }
                        if (driverDot.index < driverDot.rawPoints.length - 1) {
                            reachedEnd = false;
                        }
                        const currentPoint = driverDot.mappedPoints[driverDot.index];
                        driverDot.dotMesh.position.set(currentPoint.x, currentPoint.y, 1);
                        driverDot.dotMesh.visible = !isDriverStationary(driverDot, driverDot.index);
                    }

                    if (reachedEnd) {
                        isPlaying = false;
                        lastRealTime = null;
                        (document.getElementById('play-pause-button') as HTMLButtonElement).textContent = 'Play';
                    }

                    const elapsed = simulatedTime - earliestTime;
                    timeDisplay.textContent = formatTime(elapsed);
                    timelineScrubber.value = String(Math.round((elapsed / totalDuration) * 1000));

                    if (!animate.lastTowerUpdate || realTimestamp - animate.lastTowerUpdate > 500) {
                        updateIntervalTower(simulatedTime);
                        animate.lastTowerUpdate = realTimestamp;
                    }

                    renderer.render(scene, camera);
                }
                (animate as any).lastTowerUpdate = 0;

                document.getElementById('play-pause-button')?.addEventListener('click', () => {
                    isPlaying = !isPlaying;
                    lastRealTime = null;
                    (document.getElementById('play-pause-button') as HTMLButtonElement).textContent = isPlaying ? 'Pause' : 'Play';
                });

                requestAnimationFrame(animate);
            }

            document.getElementById('load-track-button')?.addEventListener('click', async () => {
                const loadButton = document.getElementById('load-track-button') as HTMLButtonElement;
                loadButton.disabled = true;
                loadButton.textContent = 'Loading...';
                await loadTrack();
                loadButton.textContent = 'Reload';
                loadButton.disabled = false;
                (document.getElementById('play-pause-button') as HTMLButtonElement).disabled = false;
                (document.getElementById('timeline-scrubber') as HTMLInputElement).disabled = false;
            });
        </script>
    </body>
</html>