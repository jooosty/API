---
---
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <title>F1 Explorer</title>
    </head>
    <body>
        <div id="app">
            <select id="year-select">
                <option value="2025">2025</option>
                <option value="2024">2024</option>
                <option value="2023">2023</option>
            </select>
            <select id="meeting-select"><option value="">— Select race —</option></select>
            <select id="session-select"><option value="">— Session —</option></select>
            <select id="driver-select"><option value="">— All drivers —</option></select>

            <div id="endpoint-buttons"></div>
            <div id="url-display"></div>

            <button id="fetch-button" disabled>Fetch JSON</button>
            <button id="copy-button">Copy</button>
            <span id="status-message"></span>

            <pre id="json-output">// JSON will appear here</pre>
        </div>

        <hr />

        <h2>Track Visualiser</h2>
        <button id="load-track-button">Load Track</button>
        <label for="speed-select">Speed:</label>
        <select id="speed-select">
            <option value="1">1x</option>
            <option value="2">2x</option>
            <option value="5">5x</option>
            <option value="10" selected>10x</option>
            <option value="25">25x</option>
            <option value="50">50x</option>
        </select>
        <button id="play-pause-button" disabled>Pause</button>
        <div id="track-container" style="width: 800px; height: 600px;"></div>
        <div style="width: 800px; display: flex; align-items: center; gap: 10px; margin-top: 6px;">
            <span id="time-display" style="font-family: monospace; font-size: 13px; min-width: 50px;">0:00</span>
            <input type="range" id="timeline-scrubber" min="0" max="1000" value="0" disabled style="flex: 1;" />
            <span id="time-total" style="font-family: monospace; font-size: 13px; min-width: 50px;"></span>
        </div>

        <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
        <script>
            // ── JSON Explorer ─────────────────────────────────────────────

            const BASE_URL = 'https://api.openf1.org/v1';
            const ENDPOINTS = [
                { label: 'Drivers', path: '/drivers' },
                { label: 'Results', path: '/session_result' },
                { label: 'Laps', path: '/laps' },
                { label: 'Stints', path: '/stints' },
                { label: 'Pit Stops', path: '/pit' },
                { label: 'Position', path: '/position' },
                { label: 'Intervals', path: '/intervals' },
                { label: 'Race Control', path: '/race_control' },
                { label: 'Weather', path: '/weather' },
                { label: 'Starting Grid', path: '/starting_grid' },
                { label: 'Team Radio', path: '/team_radio' },
                { label: 'Overtakes', path: '/overtakes' },
                { label: 'Car Data', path: '/car_data' },
            ];

            const ENDPOINTS_WITHOUT_DRIVER_FILTER = [
                '/session_result',
                '/race_control',
                '/weather',
                '/starting_grid',
            ];

            let selectedSessionKey: string | null = null;
            let selectedDriverNumber: string | null = null;
            let activeEndpointPath: string = ENDPOINTS[0].path;

            const endpointButtonsContainer = document.getElementById('endpoint-buttons');
            ENDPOINTS.forEach(endpoint => {
                const button = document.createElement('button');
                button.textContent = endpoint.label;
                button.addEventListener('click', () => {
                    activeEndpointPath = endpoint.path;
                    updateUrlDisplay();
                });
                endpointButtonsContainer?.appendChild(button);
            });

            function buildRequestUrl() {
                let url = `${BASE_URL}${activeEndpointPath}?session_key=${selectedSessionKey}`;
                const driverFilterAllowed = !ENDPOINTS_WITHOUT_DRIVER_FILTER.includes(activeEndpointPath);
                if (selectedDriverNumber && driverFilterAllowed) {
                    if (activeEndpointPath === '/overtakes') {
                        url += `&overtaking_driver_number=${selectedDriverNumber}&overtaken_driver_number=${selectedDriverNumber}`;
                    } else {
                        url += `&driver_number=${selectedDriverNumber}`;
                    }
                }
                return url;
            }

            async function fetchAndMergeOvertakes(): Promise<any[]> {
                const overtakingUrl = `${BASE_URL}/overtakes?session_key=${selectedSessionKey}&overtaking_driver_number=${selectedDriverNumber}`;
                const overtakenUrl = `${BASE_URL}/overtakes?session_key=${selectedSessionKey}&overtaken_driver_number=${selectedDriverNumber}`;

                const [overtakingResults, overtakenResults] = await Promise.all([
                    fetch(overtakingUrl).then(response => response.json()),
                    fetch(overtakenUrl).then(response => response.json()),
                ]);

                const mergedResults = [...overtakingResults, ...overtakenResults];
                mergedResults.sort((entryA: any, entryB: any) => new Date(entryA.date).getTime() - new Date(entryB.date).getTime());
                return mergedResults;
            }

            function updateUrlDisplay() {
                const urlDisplay = document.getElementById('url-display');
                if (!selectedSessionKey || !urlDisplay) return;

                if (activeEndpointPath === '/overtakes' && selectedDriverNumber) {
                    urlDisplay.textContent = `${BASE_URL}/overtakes?session_key=${selectedSessionKey}&overtaking_driver_number=${selectedDriverNumber} + overtaken_driver_number=${selectedDriverNumber} (merged)`;
                } else {
                    urlDisplay.textContent = buildRequestUrl();
                }

                (document.getElementById('fetch-button') as HTMLButtonElement).disabled = false;
            }

            async function loadMeetings() {
                const selectedYear = (document.getElementById('year-select') as HTMLSelectElement).value;
                const meetingsData = await fetch(`${BASE_URL}/meetings?year=${selectedYear}`).then(response => response.json());
                meetingsData.sort((meetingA: any, meetingB: any) => new Date(meetingA.date_start).getTime() - new Date(meetingB.date_start).getTime());
                const meetingSelect = document.getElementById('meeting-select') as HTMLSelectElement;
                meetingSelect.innerHTML = '<option value="">— Select race —</option>';
                meetingsData.forEach((meeting: any) => {
                    const option = document.createElement('option');
                    option.value = meeting.meeting_key;
                    option.textContent = meeting.meeting_name;
                    meetingSelect.appendChild(option);
                });
                (document.getElementById('session-select') as HTMLSelectElement).innerHTML = '<option value="">— Session —</option>';
                (document.getElementById('driver-select') as HTMLSelectElement).innerHTML = '<option value="">— All drivers —</option>';
                selectedSessionKey = null;
                selectedDriverNumber = null;
                (document.getElementById('fetch-button') as HTMLButtonElement).disabled = true;
                updateUrlDisplay();
            }

            async function loadSessions() {
                const meetingSelect = document.getElementById('meeting-select') as HTMLSelectElement;
                if (!meetingSelect.value) return;
                const sessionsData = await fetch(`${BASE_URL}/sessions?meeting_key=${meetingSelect.value}`).then(response => response.json());
                const sessionSelect = document.getElementById('session-select') as HTMLSelectElement;
                sessionSelect.innerHTML = '<option value="">— Session —</option>';
                sessionsData.forEach((session: any) => {
                    const option = document.createElement('option');
                    option.value = session.session_key;
                    option.textContent = session.session_name;
                    sessionSelect.appendChild(option);
                });
                selectedSessionKey = null;
                selectedDriverNumber = null;
                (document.getElementById('driver-select') as HTMLSelectElement).innerHTML = '<option value="">— All drivers —</option>';
                (document.getElementById('fetch-button') as HTMLButtonElement).disabled = true;
                updateUrlDisplay();
            }

            async function loadDrivers(sessionKey: string) {
                const driversData = await fetch(`${BASE_URL}/drivers?session_key=${sessionKey}`).then(response => response.json());
                driversData.sort((driverA: any, driverB: any) => driverA.driver_number - driverB.driver_number);
                const driverSelect = document.getElementById('driver-select') as HTMLSelectElement;
                driverSelect.innerHTML = '<option value="">— All drivers —</option>';
                driversData.forEach((driver: any) => {
                    const option = document.createElement('option');
                    option.value = driver.driver_number;
                    option.textContent = `${driver.name_acronym} — #${driver.driver_number} — ${driver.team_name}`;
                    driverSelect.appendChild(option);
                });
            }

            async function fetchJson() {
                const statusMessage = document.getElementById('status-message');
                const jsonOutput = document.getElementById('json-output');
                if (!statusMessage || !jsonOutput) return;
                statusMessage.textContent = 'Fetching...';
                jsonOutput.textContent = '// loading...';
                try {
                    const startTime = Date.now();
                    let responseData: any;

                    if (activeEndpointPath === '/overtakes' && selectedDriverNumber) {
                        responseData = await fetchAndMergeOvertakes();
                    } else {
                        responseData = await fetch(buildRequestUrl()).then(response => response.json());
                    }

                    jsonOutput.textContent = JSON.stringify(responseData, null, 2);
                    statusMessage.textContent = `${Array.isArray(responseData) ? responseData.length + ' records' : 'object'} · ${Date.now() - startTime}ms`;
                } catch (error: any) {
                    statusMessage.textContent = error.message;
                    jsonOutput.textContent = '// error: ' + error.message;
                }
            }

            function copyJson() {
                const jsonOutput = document.getElementById('json-output');
                if (jsonOutput) navigator.clipboard.writeText(jsonOutput.textContent ?? '').catch(() => {});
            }

            document.getElementById('year-select')?.addEventListener('change', loadMeetings);
            document.getElementById('meeting-select')?.addEventListener('change', loadSessions);

            document.getElementById('session-select')?.addEventListener('change', async function () {
                const sessionSelect = this as HTMLSelectElement;
                selectedSessionKey = sessionSelect.value || null;
                selectedDriverNumber = null;
                (document.getElementById('driver-select') as HTMLSelectElement).innerHTML = '<option value="">— All drivers —</option>';
                if (selectedSessionKey) {
                    await loadDrivers(selectedSessionKey);
                }
                updateUrlDisplay();
            });

            document.getElementById('driver-select')?.addEventListener('change', function () {
                const driverSelect = this as HTMLSelectElement;
                selectedDriverNumber = driverSelect.value || null;
                updateUrlDisplay();
            });

            document.getElementById('fetch-button')?.addEventListener('click', fetchJson);
            document.getElementById('copy-button')?.addEventListener('click', copyJson);

            loadMeetings();

            // ── Track Visualiser ──────────────────────────────────────────

            const scene = new THREE.Scene();
            scene.background = new THREE.Color(0x1a1a1a);

            const camera = new THREE.OrthographicCamera(-400, 400, 300, -300, 0.1, 1000);
            camera.position.set(0, 0, 100);
            camera.lookAt(0, 0, 0);

            const renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(800, 600);
            renderer.setPixelRatio(window.devicePixelRatio);

            document.getElementById('track-container')?.appendChild(renderer.domElement);

            async function loadTrack() {
                const sessionKey = selectedSessionKey;
                if (!sessionKey) {
                    alert('Please select a session first.');
                    return;
                }

                function delay(ms: number): Promise<void> {
                    return new Promise(resolve => setTimeout(resolve, ms));
                }

                // loading label shown on the canvas while fetching
                const loadingCanvas = document.createElement('canvas');
                loadingCanvas.width = 512;
                loadingCanvas.height = 64;
                const loadingContext = loadingCanvas.getContext('2d') as CanvasRenderingContext2D;

                const loadingTexture = new THREE.CanvasTexture(loadingCanvas);
                const loadingMaterial = new THREE.SpriteMaterial({ map: loadingTexture });
                const loadingSprite = new THREE.Sprite(loadingMaterial);
                loadingSprite.scale.set(400, 50, 1);
                loadingSprite.position.set(0, 0, 1);
                scene.add(loadingSprite);

                function setLoadingText(text: string): void {
                    loadingContext.clearRect(0, 0, loadingCanvas.width, loadingCanvas.height);
                    loadingContext.fillStyle = '#ffffff';
                    loadingContext.font = 'bold 48px monospace';
                    loadingContext.textAlign = 'center';
                    loadingContext.fillText(text, loadingCanvas.width / 2, 52);
                    loadingTexture.needsUpdate = true;
                    renderer.render(scene, camera);
                }

                setLoadingText('Fetching session...');

                // clear any previously loaded track and dots
                scene.clear();
                scene.background = new THREE.Color(0x1a1a1a);
                scene.add(loadingSprite);
                renderer.render(scene, camera);

                // fetch session date range
                const sessionData = await fetch(
                    `${BASE_URL}/sessions?session_key=${sessionKey}`
                ).then(r => r.json());

                const dateStart = new Date(sessionData[0].date_start).toISOString();
                const dateEnd = new Date(sessionData[0].date_end).toISOString();

                await delay(500);

                setLoadingText('Fetching drivers...');

                // fetch all drivers in the session
                const driversData = await fetch(
                    `${BASE_URL}/drivers?session_key=${sessionKey}`
                ).then(r => r.json());

                // wait 1 second after fetching drivers before starting location requests
                await delay(1000);

                // fetch location data for each driver sequentially to respect rate limit
                // 500ms between requests = 2 per second, well under the 3/sec limit
                const allDriverLocationData: { driver: any; points: any[] }[] = [];
                for (const driver of driversData) {
                    setLoadingText(`Loading ${driver.name_acronym} (${allDriverLocationData.length + 1}/${driversData.length})`);
                    const points = await fetch(
                        `${BASE_URL}/location?session_key=${sessionKey}&driver_number=${driver.driver_number}&date>=${dateStart}&date<=${dateEnd}`
                    ).then(r => r.json());
                    if (points.length > 0) {
                        allDriverLocationData.push({ driver, points });
                    }
                    await delay(500);
                }

                // remove loading sprite once done
                scene.remove(loadingSprite);

                // combine all points to compute a shared center and scale
                const allPoints = allDriverLocationData.flatMap(d => d.points);

                const minX = allPoints.reduce((min: number, p: any) => p.x < min ? p.x : min, Infinity);
                const maxX = allPoints.reduce((max: number, p: any) => p.x > max ? p.x : max, -Infinity);
                const minY = allPoints.reduce((min: number, p: any) => p.y < min ? p.y : min, Infinity);
                const maxY = allPoints.reduce((max: number, p: any) => p.y > max ? p.y : max, -Infinity);

                const centerX = (minX + maxX) / 2;
                const centerY = (minY + maxY) / 2;

                const trackWidth = (maxX - minX) * 0.1;
                const trackHeight = (maxY - minY) * 0.1;
                const scale = Math.min(700 / trackWidth, 500 / trackHeight) * 0.9;

                function toTrackPoint(point: any): any {
                    return new THREE.Vector3(
                        (point.x - centerX) * 0.1 * scale,
                        (point.y - centerY) * 0.1 * scale,
                        0
                    );
                }

                // draw track line from the driver with the most points
                const mostPoints = allDriverLocationData.reduce((best, current) =>
                    current.points.length > best.points.length ? current : best
                );
                const trackLinePoints = mostPoints.points.map(toTrackPoint);
                const trackGeometry = new THREE.BufferGeometry().setFromPoints(trackLinePoints);
                const trackMaterial = new THREE.LineBasicMaterial({ color: 0x444444 });
                const trackLine = new THREE.Line(trackGeometry, trackMaterial);
                scene.add(trackLine);

                // create a dot and mapped points array for each driver
                const driverDots = allDriverLocationData.map(({ driver, points }) => {
                    const teamColor = driver.team_colour ? parseInt(driver.team_colour, 16) : 0xffffff;
                    const dotMesh = new THREE.Mesh(
                        new THREE.CircleGeometry(5, 32),
                        new THREE.MeshBasicMaterial({ color: teamColor })
                    );
                    const mappedPoints = points.map(toTrackPoint);
                    dotMesh.position.set(mappedPoints[0].x, mappedPoints[0].y, 1);
                    scene.add(dotMesh);
                    return { dotMesh, mappedPoints, rawPoints: points, index: 0 };
                });

                let zoomLevel: number = 1;
                let isPanning: boolean = false;
                let panStartX: number = 0;
                let panStartY: number = 0;
                let cameraOffsetX: number = 0;
                let cameraOffsetY: number = 0;

                function updateCamera(): void {
                    const baseWidth = 400;
                    const baseHeight = 300;
                    camera.left = -baseWidth / zoomLevel + cameraOffsetX;
                    camera.right = baseWidth / zoomLevel + cameraOffsetX;
                    camera.top = baseHeight / zoomLevel + cameraOffsetY;
                    camera.bottom = -baseHeight / zoomLevel + cameraOffsetY;
                    camera.updateProjectionMatrix();
                    renderer.render(scene, camera);
                }

                renderer.domElement.addEventListener('wheel', (wheelEvent: WheelEvent) => {
                    wheelEvent.preventDefault();
                    zoomLevel *= wheelEvent.deltaY < 0 ? 1.1 : 0.9;
                    zoomLevel = Math.max(0.5, Math.min(20, zoomLevel));
                    updateCamera();
                });

                renderer.domElement.addEventListener('mousedown', (mouseEvent: MouseEvent) => {
                    isPanning = true;
                    panStartX = mouseEvent.clientX;
                    panStartY = mouseEvent.clientY;
                });

                renderer.domElement.addEventListener('mousemove', (mouseEvent: MouseEvent) => {
                    if (!isPanning) return;
                    const deltaX = (mouseEvent.clientX - panStartX) / zoomLevel;
                    const deltaY = (mouseEvent.clientY - panStartY) / zoomLevel;
                    panStartX = mouseEvent.clientX;
                    panStartY = mouseEvent.clientY;
                    cameraOffsetX -= deltaX;
                    cameraOffsetY += deltaY;
                    updateCamera();
                });

                renderer.domElement.addEventListener('mouseup', () => { isPanning = false; });
                renderer.domElement.addEventListener('mouseleave', () => { isPanning = false; });

                let lastRealTime: number | null = null;
                const earliestTime: number = Math.min(
                    ...allDriverLocationData.map(d => new Date(d.points[0].date).getTime())
                );
                const latestTime: number = Math.max(
                    ...allDriverLocationData.map(d => new Date(d.points[d.points.length - 1].date).getTime())
                );
                const totalDuration: number = latestTime - earliestTime;
                let simulatedTime: number = earliestTime;
                let isPlaying: boolean = true;
                let isScrubbing: boolean = false;

                const timelineScrubber = document.getElementById('timeline-scrubber') as HTMLInputElement;
                const timeDisplay = document.getElementById('time-display') as HTMLElement;
                const timeTotal = document.getElementById('time-total') as HTMLElement;

                timelineScrubber.disabled = false;
                timeTotal.textContent = formatTime(totalDuration);

                function formatTime(ms: number): string {
                    const totalSeconds = Math.floor(ms / 1000);
                    const hours = Math.floor(totalSeconds / 3600);
                    const minutes = Math.floor((totalSeconds % 3600) / 60);
                    const seconds = totalSeconds % 60;
                    if (hours > 0) {
                        return `${hours}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
                    }
                    return `${minutes}:${String(seconds).padStart(2, '0')}`;
                }

                function updateAllDriversToTime(targetTime: number): void {
                    for (const driverDot of driverDots) {
                        // reset index if we scrubbed backwards
                        if (new Date(driverDot.rawPoints[driverDot.index].date).getTime() > targetTime) {
                            driverDot.index = 0;
                        }
                        while (
                            driverDot.index < driverDot.rawPoints.length - 1 &&
                            new Date(driverDot.rawPoints[driverDot.index + 1].date).getTime() < targetTime
                        ) {
                            driverDot.index++;
                        }
                        const currentPoint = driverDot.mappedPoints[driverDot.index];
                        driverDot.dotMesh.position.set(currentPoint.x, currentPoint.y, 1);
                    }
                    const elapsed = targetTime - earliestTime;
                    timeDisplay.textContent = formatTime(elapsed);
                    timelineScrubber.value = String(Math.round((elapsed / totalDuration) * 1000));
                    renderer.render(scene, camera);
                }

                timelineScrubber.addEventListener('mousedown', () => {
                    isScrubbing = true;
                    isPlaying = false;
                    lastRealTime = null;
                    (document.getElementById('play-pause-button') as HTMLButtonElement).textContent = 'Play';
                });

                timelineScrubber.addEventListener('input', () => {
                    const fraction = Number(timelineScrubber.value) / 1000;
                    simulatedTime = earliestTime + fraction * totalDuration;
                    updateAllDriversToTime(simulatedTime);
                });

                timelineScrubber.addEventListener('mouseup', () => {
                    isScrubbing = false;
                });

                function animate(realTimestamp: number): void {
                    requestAnimationFrame(animate);

                    if (!isPlaying || isScrubbing) return;

                    if (lastRealTime === null) lastRealTime = realTimestamp;
                    const realElapsed = realTimestamp - lastRealTime;
                    lastRealTime = realTimestamp;

                    const speedMultiplier = Number((document.getElementById('speed-select') as HTMLSelectElement).value);
                    simulatedTime += realElapsed * speedMultiplier;

                    let reachedEnd = false;

                    for (const driverDot of driverDots) {
                        while (
                            driverDot.index < driverDot.rawPoints.length - 1 &&
                            new Date(driverDot.rawPoints[driverDot.index + 1].date).getTime() < simulatedTime
                        ) {
                            driverDot.index++;
                        }
                        if (driverDot.index >= driverDot.rawPoints.length - 1) {
                            reachedEnd = true;
                        }
                        const currentPoint = driverDot.mappedPoints[driverDot.index];
                        driverDot.dotMesh.position.set(currentPoint.x, currentPoint.y, 1);
                    }

                    if (reachedEnd) {
                        for (const driverDot of driverDots) {
                            driverDot.index = 0;
                        }
                        simulatedTime = earliestTime;
                    }

                    const elapsed = simulatedTime - earliestTime;
                    timeDisplay.textContent = formatTime(elapsed);
                    timelineScrubber.value = String(Math.round((elapsed / totalDuration) * 1000));

                    renderer.render(scene, camera);
                }

                document.getElementById('play-pause-button')?.addEventListener('click', () => {
                    isPlaying = !isPlaying;
                    lastRealTime = null;
                    (document.getElementById('play-pause-button') as HTMLButtonElement).textContent = isPlaying ? 'Pause' : 'Play';
                });

                requestAnimationFrame(animate);
            }

            document.getElementById('load-track-button')?.addEventListener('click', async () => {
                const loadButton = document.getElementById('load-track-button') as HTMLButtonElement;
                loadButton.disabled = true;
                loadButton.textContent = 'Loading...';
                await loadTrack();
                loadButton.textContent = 'Reload';
                loadButton.disabled = false;
                (document.getElementById('play-pause-button') as HTMLButtonElement).disabled = false;
                (document.getElementById('timeline-scrubber') as HTMLInputElement).disabled = false;
            });
        </script>
    </body>
</html>