---
---
<div id="visualiser-section">
<div class="visualiser-header">
    <h2>Track Visualiser</h2>
    <span id="active-session-label" class="active-session-label"></span>
</div>
<div class="visualiser-controls">
    <button id="load-track-button" class="primary">Load Track</button>
    <label for="speed-select">Speed:</label>
    <select id="speed-select">
        <option value="1">1x</option>
        <option value="2">2x</option>
        <option value="5">5x</option>
        <option value="10" selected>10x</option>
        <option value="25">25x</option>
        <option value="50">50x</option>
    </select>
    <button id="play-pause-button" disabled>Pause</button>
</div>
<div class="visualiser-layout">
    <div class="track-wrap">
        <div id="track-container"></div>
        <div id="interval-tower">
            <div class="tower-header">Intervals</div>
            <div id="phase-indicator"></div>
            <div id="interval-rows">
                <div class="tower-empty">Load track to show</div>
            </div>
        </div>
        <div id="weather-overlay">
            <span id="wx-track">—</span><span class="wx-label">TRK</span>
            <span id="wx-air">—</span><span class="wx-label">AIR</span>
            <span id="wx-humid">—</span><span class="wx-label">HUM</span>
            <span id="wx-wind">—</span><span class="wx-label">WND</span>
            <span id="wx-rain" class="wx-rain-badge">DRY</span>
        </div>
        <div id="radio-popup" class="radio-popup hidden">
            <div class="radio-popup-header">
                <span id="radio-dot" class="radio-dot"></span>
                <span id="radio-acronym" class="radio-acronym"></span>
                <span class="radio-live-badge">RADIO</span>
                <button id="radio-close" class="radio-close">✕</button>
            </div>
            <div class="radio-popup-controls">
                <button id="radio-play-btn" class="radio-play-btn">▶ Play</button>
                <div class="radio-progress-wrap">
                    <div id="radio-progress-bar" class="radio-progress-bar"></div>
                </div>
                <span id="radio-time" class="radio-time">0:00</span>
            </div>
        </div>
        <div class="timeline-row">
            <span id="time-display">0:00</span>
            <input type="range" id="timeline-scrubber" min="0" max="1000" value="0" disabled />
            <span id="time-total"></span>
        </div>
    </div>
    <div id="live-lap-tower">
        <div class="tower-header">On Lap</div>
        <div id="live-lap-rows">
            <div class="tower-empty">Load track to show</div>
        </div>
    </div>
    <div id="pit-tower">
        <div class="tower-header">Pit Stops</div>
        <div id="pit-tower-rows">
            <div class="tower-empty">Load track to show</div>
        </div>
    </div>
</div>
</div>

<script>
    import * as THREE from 'three';
    import { BASE_URL } from '../scripts/constants.js';
    import { updatePracticeTower }   from '../scripts/tower-practice.js';
    import { updateQualifyingTower } from '../scripts/tower-qualifying.js';
    import { updateRaceTower }       from '../scripts/tower-race.js';
    import { updateLiveLapTower }    from '../scripts/tower-live-lap.js';
    import { buildPitTowerState, updatePitTower } from '../scripts/tower-pit.js';

    // ── Scene setup ───────────────────────────────────────────
    const scene = new THREE.Scene();
    scene.background = new THREE.Color(0x1a1a1a);

    const camera = new THREE.OrthographicCamera(-400, 400, 300, -300, 0.1, 1000);
    camera.position.set(0, 0, 100);
    camera.lookAt(0, 0, 0);

    const renderer = new THREE.WebGLRenderer({ antialias: true });
    renderer.setSize(800, 600);
    renderer.setPixelRatio(window.devicePixelRatio);
    document.getElementById('track-container')?.appendChild(renderer.domElement);

    function setLoadControls(isLoading) {
        const loadButton = document.getElementById('load-track-button');
        const playPauseButton = document.getElementById('play-pause-button');
        const timelineScrubber = document.getElementById('timeline-scrubber');

        if (loadButton) {
            loadButton.disabled = isLoading;
            loadButton.textContent = isLoading ? 'Loading...' : 'Reload';
        }
        if (playPauseButton) playPauseButton.disabled = isLoading;
        if (timelineScrubber) timelineScrubber.disabled = isLoading;
    }

    async function startTrackLoad() {
        setLoadControls(true);
        try {
            await loadTrack();
        } finally {
            setLoadControls(false);
        }
    }

    let currentSessionKey = null;
    window.addEventListener('session-changed', (e) => {
        currentSessionKey = e.detail.sessionKey;
        const label = document.getElementById('active-session-label');
        if (label) {
            label.textContent = `${e.detail.meetingName} — ${e.detail.sessionName}`;
        }

        void startTrackLoad();
    });

    // ── Load track ────────────────────────────────────────────
    async function loadTrack() {
        const sessionKey = currentSessionKey;
        if (!sessionKey) {
            alert('Please select a session first.');
            return;
        }

        const delay = (ms) => new Promise(resolve => setTimeout(resolve, ms));

        // ── Rate limiter: max 3/sec, 28/min (2 headroom) ─────
        const requestLog = [];
        const PER_SEC  = 3;
        const PER_MIN  = 28;

        async function apiFetch(url) {
            const now = () => Date.now();

            while (true) {
                const t = now();
                // drop entries older than 60s
                while (requestLog.length && requestLog[0] < t - 60_000) requestLog.shift();

                const recentSec = requestLog.filter(ts => ts > t - 1_000).length;
                const recentMin = requestLog.length;

                if (recentSec >= PER_SEC) {
                    // wait until the oldest within the last second ages out
                    const oldest1s = requestLog.find(ts => ts > t - 1_000);
                    await delay(1_000 - (t - oldest1s) + 50);
                    continue;
                }
                if (recentMin >= PER_MIN) {
                    // wait until the oldest within 60s ages out
                    await delay(60_000 - (t - requestLog[0]) + 50);
                    continue;
                }

                // clear to send
                requestLog.push(now());
                const res = await fetch(url);
                if (res.status === 429) {
                    // unexpected 429 — back off 10s and retry
                    requestLog.pop();
                    setLoadingText('Rate limited — waiting 10s...');
                    await delay(10_000);
                    continue;
                }
                return res.json();
            }
        }

        // Loading sprite
        const loadingCanvas = document.createElement('canvas');
        loadingCanvas.width = 1024;
        loadingCanvas.height = 80;
        const loadingContext = loadingCanvas.getContext('2d');
        const loadingTexture = new THREE.CanvasTexture(loadingCanvas);
        const loadingSprite  = new THREE.Sprite(new THREE.SpriteMaterial({ map: loadingTexture }));
        loadingSprite.scale.set(700, 55, 1);
        loadingSprite.position.set(0, 0, 1);
        scene.add(loadingSprite);

        function setLoadingText(text) {
            loadingContext.clearRect(0, 0, loadingCanvas.width, loadingCanvas.height);
            loadingContext.fillStyle = '#ffffff';
            loadingContext.font = 'bold 44px monospace';
            loadingContext.textAlign = 'center';
            loadingContext.fillText(text, loadingCanvas.width / 2, 56);
            loadingTexture.needsUpdate = true;
            renderer.render(scene, camera);
        }

        setLoadingText('Fetching session...');
        scene.clear();
        scene.background = new THREE.Color(0x1a1a1a);
        scene.add(loadingSprite);
        renderer.render(scene, camera);

        // ── Fetch session + drivers ───────────────────────────
        const sessionData = await apiFetch(`${BASE_URL}/sessions?session_key=${sessionKey}`);
        setLoadingText('Fetching drivers...');
        const driversData = await apiFetch(`${BASE_URL}/drivers?session_key=${sessionKey}`);

        const sessionType  = (sessionData[0].session_type || '').toLowerCase();
        const isPractice   = sessionType.includes('practice');
        const isQualifying = sessionType.includes('qualifying');

        // ── Fetch tower data ──────────────────────────────────
        let allIntervalData    = [];
        let allPositionData    = [];
        let allLapData         = [];
        let allStintData       = [];
        let allPitData         = [];
        let allWeatherData     = [];
        let allRadioData       = [];
        let qualPhaseBoundaries = [];
        const dnfDrivers = new Set();

        if (isPractice) {
            setLoadingText('Fetching lap times...');
            const lapRaw = await apiFetch(`${BASE_URL}/laps?session_key=${sessionKey}`);
            allLapData = Array.isArray(lapRaw) ? lapRaw : [];

            setLoadingText('Fetching stints...');
            const stintRaw = await apiFetch(`${BASE_URL}/stints?session_key=${sessionKey}`);
            allStintData = Array.isArray(stintRaw) ? stintRaw : [];

            setLoadingText('Fetching pit stops...');
            const pitRaw = await apiFetch(`${BASE_URL}/pit?session_key=${sessionKey}`);
            allPitData = Array.isArray(pitRaw) ? pitRaw.sort((a, b) => new Date(a.date) - new Date(b.date)) : [];

        } else if (isQualifying) {
            setLoadingText('Fetching lap times...');
            const lapRaw = await apiFetch(`${BASE_URL}/laps?session_key=${sessionKey}`);
            allLapData = Array.isArray(lapRaw) ? lapRaw : [];

            setLoadingText('Fetching stints...');
            const stintRaw = await apiFetch(`${BASE_URL}/stints?session_key=${sessionKey}`);
            allStintData = Array.isArray(stintRaw) ? stintRaw : [];

            setLoadingText('Fetching pit stops...');
            const pitRaw = await apiFetch(`${BASE_URL}/pit?session_key=${sessionKey}`);
            allPitData = Array.isArray(pitRaw) ? pitRaw.sort((a, b) => new Date(a.date) - new Date(b.date)) : [];

            setLoadingText('Fetching race control...');
            const rcRaw  = await apiFetch(`${BASE_URL}/race_control?session_key=${sessionKey}`);
            const rcData = Array.isArray(rcRaw) ? rcRaw : [];

            const phaseStartTimes = {};
            for (const event of rcData) {
                if (!event.qualifying_phase || !event.date) continue;
                const phase = Number(event.qualifying_phase);
                const t = new Date(event.date).getTime();
                if (!phaseStartTimes[phase] || t < phaseStartTimes[phase]) phaseStartTimes[phase] = t;
            }
            for (let p = 1; p <= 2; p++) {
                if (phaseStartTimes[p + 1]) qualPhaseBoundaries.push(phaseStartTimes[p + 1]);
            }
            console.log('[QUALI INIT] phase starts:', phaseStartTimes, '| boundaries:', qualPhaseBoundaries.map(b => new Date(b).toISOString()));

        } else {
            setLoadingText('Fetching intervals...');
            const ivRaw = await apiFetch(`${BASE_URL}/intervals?session_key=${sessionKey}`);
            allIntervalData = Array.isArray(ivRaw) ? ivRaw : [];

            setLoadingText('Fetching positions...');
            const posRaw = await apiFetch(`${BASE_URL}/position?session_key=${sessionKey}`);
            allPositionData = Array.isArray(posRaw) ? posRaw : [];

            setLoadingText('Fetching results...');
            const sessionResultRaw  = await apiFetch(`${BASE_URL}/session_result?session_key=${sessionKey}`);
            const sessionResultData = Array.isArray(sessionResultRaw) ? sessionResultRaw : [];
            sessionResultData.filter(r => r.dnf || r.dns || r.dsq).forEach(r => dnfDrivers.add(r.driver_number));

            setLoadingText('Fetching pit stops...');
            const pitRaw = await apiFetch(`${BASE_URL}/pit?session_key=${sessionKey}`);
            allPitData = Array.isArray(pitRaw) ? pitRaw.sort((a, b) => new Date(a.date) - new Date(b.date)) : [];

            setLoadingText('Fetching stints...');
            const stintRaw = await apiFetch(`${BASE_URL}/stints?session_key=${sessionKey}`);
            allStintData = Array.isArray(stintRaw) ? stintRaw : [];
        }

        // ── Fetch weather (all session types) ────────────────
        setLoadingText('Fetching weather...');
        const wxRaw = await apiFetch(`${BASE_URL}/weather?session_key=${sessionKey}`);
        allWeatherData = Array.isArray(wxRaw) ? wxRaw.sort((a, b) => new Date(a.date) - new Date(b.date)) : [];

        // ── Fetch team radio (all session types) ──────────────
        setLoadingText('Fetching team radio...');
        const radioRaw = await apiFetch(`${BASE_URL}/team_radio?session_key=${sessionKey}`);
        allRadioData = Array.isArray(radioRaw)
            ? radioRaw.sort((a, b) => new Date(a.date) - new Date(b.date))
            : [];

        // ── Driver info map ───────────────────────────────────
        const driverInfoMap = {};
        driversData.forEach(d => {
            driverInfoMap[d.driver_number] = {
                acronym: d.name_acronym || ('#' + d.driver_number),
                colour:  d.team_colour ? '#' + d.team_colour : '#ffffff',
            };
        });

        // ── Fetch location data (bulk, time-chunked) ──────────
        // Instead of one request per driver, fetch all drivers at once
        // but split the session into 4 time windows to keep response
        // sizes manageable, then reassemble and group by driver in JS.
        const sessionStart = new Date(sessionData[0].date_start).getTime();
        const sessionEnd   = sessionData[0].date_end
            ? new Date(sessionData[0].date_end).getTime()
            : sessionStart + 3 * 60 * 60 * 1000; // fallback: 3h

        const CHUNKS     = 4;
        const chunkMs    = Math.ceil((sessionEnd - sessionStart) / CHUNKS);
        const rawByDriver = {}; // driverNumber → point[]

        for (let i = 0; i < CHUNKS; i++) {
            const chunkStart = new Date(sessionStart + i * chunkMs).toISOString();
            const chunkEnd   = new Date(Math.min(sessionStart + (i + 1) * chunkMs, sessionEnd)).toISOString();
            setLoadingText(`Loading track data… (${i + 1}/${CHUNKS})`);

            const chunkPoints = await apiFetch(
                `${BASE_URL}/location?session_key=${sessionKey}&date>=${chunkStart}&date<${chunkEnd}`
            );

            if (Array.isArray(chunkPoints)) {
                for (const pt of chunkPoints) {
                    const dn = pt.driver_number;
                    if (!rawByDriver[dn]) rawByDriver[dn] = [];
                    rawByDriver[dn].push(pt);
                }
            }
        }

        // Build the same shape as before: [{ driver, points }]
        // Sort each driver's points by date so playback is in order
        const allDriverLocationData = [];
        for (const driver of driversData) {
            const pts = rawByDriver[driver.driver_number];
            if (!pts || pts.length === 0) continue;
            pts.sort((a, b) => new Date(a.date) - new Date(b.date));
            allDriverLocationData.push({ driver, points: pts });
        }

        scene.remove(loadingSprite);

        // ── Build track geometry ──────────────────────────────
        const allPoints = allDriverLocationData.flatMap(d => d.points);
        const minX = allPoints.reduce((m, p) => p.x < m ? p.x : m, Infinity);
        const maxX = allPoints.reduce((m, p) => p.x > m ? p.x : m, -Infinity);
        const minY = allPoints.reduce((m, p) => p.y < m ? p.y : m, Infinity);
        const maxY = allPoints.reduce((m, p) => p.y > m ? p.y : m, -Infinity);

        const centerX = (minX + maxX) / 2;
        const centerY = (minY + maxY) / 2;
        const scale   = Math.min(700 / ((maxX - minX) * 0.1), 500 / ((maxY - minY) * 0.1)) * 0.9;

        function toTrackPoint(point) {
            return new THREE.Vector3(
                (point.x - centerX) * 0.1 * scale,
                (point.y - centerY) * 0.1 * scale,
                0
            );
        }

        const mostPoints = allDriverLocationData.reduce((best, cur) =>
            cur.points.length > best.points.length ? cur : best
        );
        scene.add(new THREE.Line(
            new THREE.BufferGeometry().setFromPoints(mostPoints.points.map(toTrackPoint)),
            new THREE.LineBasicMaterial({ color: 0x444444 })
        ));

        // ── Driver dots ───────────────────────────────────────
        const driverDots = allDriverLocationData.map(({ driver, points }) => {
            const teamColor   = driver.team_colour ? parseInt(driver.team_colour, 16) : 0xffffff;
            const dotMesh     = new THREE.Mesh(
                new THREE.CircleGeometry(5, 32),
                new THREE.MeshBasicMaterial({ color: teamColor })
            );
            const mappedPoints = points.map(toTrackPoint);
            dotMesh.position.set(mappedPoints[0].x, mappedPoints[0].y, 1);
            scene.add(dotMesh);
            return { dotMesh, mappedPoints, rawPoints: points, index: 0 };
        });

        // ── Zoom + pan ────────────────────────────────────────
        let zoomLevel = 1, isPanning = false;
        let panStartX = 0, panStartY = 0;
        let cameraOffsetX = 0, cameraOffsetY = 0;

        function updateCamera() {
            camera.left   = -400 / zoomLevel + cameraOffsetX;
            camera.right  =  400 / zoomLevel + cameraOffsetX;
            camera.top    =  300 / zoomLevel + cameraOffsetY;
            camera.bottom = -300 / zoomLevel + cameraOffsetY;
            camera.updateProjectionMatrix();
            renderer.render(scene, camera);
        }

        renderer.domElement.addEventListener('wheel', e => {
            e.preventDefault();
            zoomLevel = Math.max(0.5, Math.min(20, zoomLevel * (e.deltaY < 0 ? 1.1 : 0.9)));
            updateCamera();
        });
        renderer.domElement.addEventListener('mousedown', e => { isPanning = true; panStartX = e.clientX; panStartY = e.clientY; });
        renderer.domElement.addEventListener('mousemove', e => {
            if (!isPanning) return;
            cameraOffsetX -= (e.clientX - panStartX) / zoomLevel;
            cameraOffsetY += (e.clientY - panStartY) / zoomLevel;
            panStartX = e.clientX; panStartY = e.clientY;
            updateCamera();
        });
        renderer.domElement.addEventListener('mouseup',    () => { isPanning = false; });
        renderer.domElement.addEventListener('mouseleave', () => { isPanning = false; });

        // ── Timeline ──────────────────────────────────────────
        const firstLocationTime = Math.min(...allDriverLocationData.map(d => new Date(d.points[0].date).getTime()));
        const firstLapTime      = allLapData.length > 0
            ? Math.min(...allLapData.filter(l => l.date_start).map(l => new Date(l.date_start).getTime()))
            : Infinity;
        const earliestTime  = firstLapTime < Infinity ? Math.max(firstLocationTime, firstLapTime - 60_000) : firstLocationTime;
        const latestTime    = Math.max(...allDriverLocationData.map(d => new Date(d.points[d.points.length - 1].date).getTime()));
        const totalDuration = latestTime - earliestTime;

        let simulatedTime = earliestTime;
        let isPlaying = true, isScrubbing = false, lastRealTime = null;

        const timelineScrubber = document.getElementById('timeline-scrubber');
        const timeDisplay      = document.getElementById('time-display');
        const timeTotal        = document.getElementById('time-total');

        timelineScrubber.disabled = false;

        function formatTime(ms) {
            const s = Math.floor(ms / 1000);
            const h = Math.floor(s / 3600);
            const m = Math.floor((s % 3600) / 60);
            const sec = s % 60;
            if (h > 0) return `${h}:${String(m).padStart(2, '0')}:${String(sec).padStart(2, '0')}`;
            return `${m}:${String(sec).padStart(2, '0')}`;
        }

        timeTotal.textContent = formatTime(totalDuration);

        // ── Weather overlay ───────────────────────────────────
        function updateWeather(t) {
            if (allWeatherData.length === 0) return;

            // Find the latest weather reading at or before t
            let wx = allWeatherData[0];
            for (const entry of allWeatherData) {
                if (new Date(entry.date).getTime() <= t) wx = entry;
                else break;
            }

            const windDir = typeof wx.wind_direction === 'number'
                ? ['N','NE','E','SE','S','SW','W','NW'][Math.round(wx.wind_direction / 45) % 8]
                : '—';

            document.getElementById('wx-track').textContent =
                wx.track_temperature != null ? wx.track_temperature.toFixed(1) + '°' : '—';
            document.getElementById('wx-air').textContent =
                wx.air_temperature != null ? wx.air_temperature.toFixed(1) + '°' : '—';
            document.getElementById('wx-humid').textContent =
                wx.humidity != null ? wx.humidity.toFixed(0) + '%' : '—';
            document.getElementById('wx-wind').textContent =
                wx.wind_speed != null ? wx.wind_speed.toFixed(1) + ' ' + windDir : '—';

            const rainEl = document.getElementById('wx-rain');
            if (rainEl) {
                const raining = wx.rainfall === true || wx.rainfall === 1;
                rainEl.textContent = raining ? 'WET' : 'DRY';
                rainEl.style.background = raining ? '#1a3a5c' : '#1a2a1a';
                rainEl.style.color      = raining ? '#4a9eff' : '#4caf50';
                rainEl.style.borderColor = raining ? '#4a9eff' : '#4caf50';
            }
        }

        // ── Team radio popup ──────────────────────────────────
        let radioIndex       = 0;   // next unplayed entry index
        let currentAudio     = null;
        let dismissTimer     = null;
        let lastRadioSimTime = -Infinity; // track scrubbing resets

        const radioPopup    = document.getElementById('radio-popup');
        const radioDot      = document.getElementById('radio-dot');
        const radioAcronym  = document.getElementById('radio-acronym');
        const radioPlayBtn  = document.getElementById('radio-play-btn');
        const radioProgress = document.getElementById('radio-progress-bar');
        const radioTimeEl   = document.getElementById('radio-time');
        const radioClose    = document.getElementById('radio-close');

        function fmtAudioTime(sec) {
            const m = Math.floor(sec / 60);
            const s = Math.floor(sec % 60);
            return `${m}:${String(s).padStart(2, '0')}`;
        }

        function dismissRadio() {
            if (currentAudio) { currentAudio.pause(); currentAudio = null; }
            if (dismissTimer) { clearTimeout(dismissTimer); dismissTimer = null; }
            if (radioPopup) radioPopup.classList.add('hidden');
        }

        function showRadioPopup(entry) {
            const info = driverInfoMap[entry.driver_number] || { acronym: '#' + entry.driver_number, colour: '#fff' };

            radioDot.style.background    = info.colour;
            radioAcronym.textContent     = info.acronym;
            radioProgress.style.width    = '0%';
            radioTimeEl.textContent      = '0:00';
            radioPlayBtn.textContent     = '▶ Play';

            // Stop any previous audio
            if (currentAudio) { currentAudio.pause(); currentAudio = null; }

            const audio = new Audio(entry.recording_url + '?_=' + Date.now());
            currentAudio = audio;

            audio.addEventListener('timeupdate', () => {
                if (!audio.duration) return;
                radioProgress.style.width = (audio.currentTime / audio.duration * 100) + '%';
                radioTimeEl.textContent   = fmtAudioTime(audio.currentTime);
            });
            audio.addEventListener('ended', () => {
                radioPlayBtn.textContent = '▶ Play';
                radioProgress.style.width = '100%';
                // Auto-dismiss 3s after audio ends
                dismissTimer = setTimeout(dismissRadio, 3000);
            });
            audio.addEventListener('play',  () => { radioPlayBtn.textContent = '⏸ Pause'; });
            audio.addEventListener('pause', () => { radioPlayBtn.textContent = '▶ Play'; });

            radioPlayBtn.onclick = () => {
                if (audio.paused) audio.play();
                else audio.pause();
            };

            radioPopup.classList.remove('hidden');
            audio.play().catch(() => {}); // autoplay may be blocked — user can click play

            // Auto-dismiss after 15s even if not played
            if (dismissTimer) clearTimeout(dismissTimer);
            dismissTimer = setTimeout(dismissRadio, 15000);
        }

        radioClose?.addEventListener('click', dismissRadio);

        function checkRadio(t) {
            // If sim time jumped backwards (scrubbing), reset index
            if (t < lastRadioSimTime - 5000) {
                radioIndex = 0;
                dismissRadio();
            }
            lastRadioSimTime = t;

            // Advance index past any entries that have already fired
            while (radioIndex < allRadioData.length) {
                const entry = allRadioData[radioIndex];
                const entryT = new Date(entry.date).getTime();
                if (entryT <= t) {
                    showRadioPopup(entry);
                    radioIndex++;
                    break; // show one at a time; next tick will catch up if needed
                } else {
                    break;
                }
            }
        }

        // ── Pit tower ─────────────────────────────────────────
        const stintsByDriver = buildPitTowerState(allStintData);

        function checkPit(t) {
            const pitRows = document.getElementById('pit-tower-rows');
            updatePitTower(t, pitRows, allPitData, stintsByDriver, driverInfoMap);
        }

        // ── Tower dispatch ────────────────────────────────────
        function updateIntervalTower(t) {
            const intervalRows = document.getElementById('interval-rows');
            if (!intervalRows) return;
            const phaseEl = document.getElementById('phase-indicator');

            if (isPractice) {
                if (phaseEl) phaseEl.textContent = '';
                updatePracticeTower(t, intervalRows, allLapData, driverInfoMap);
            } else if (isQualifying) {
                updateQualifyingTower(t, intervalRows, allLapData, qualPhaseBoundaries, driverInfoMap);
            } else {
                if (phaseEl) phaseEl.textContent = '';
                updateRaceTower(t, intervalRows, allIntervalData, allPositionData, driverInfoMap, dnfDrivers);
            }

            // Live lap tower — practice & qualifying only
            if (isPractice || isQualifying) {
                const liveTower = document.getElementById('live-lap-tower');
                if (liveTower) liveTower.style.display = 'block';
                const liveRows = document.getElementById('live-lap-rows');
                if (liveRows) updateLiveLapTower(t, liveRows, allLapData, allStintData, driverInfoMap);
            } else {
                const liveTower = document.getElementById('live-lap-tower');
                if (liveTower) liveTower.style.display = 'none';
            }

            updateWeather(t);
            checkRadio(t);
            checkPit(t);
        }

        // ── Stationary detection ──────────────────────────────
        const STATIONARY_HIDE_MS        = 2 * 60 * 1000;
        const STATIONARY_MOVE_THRESHOLD = 5;

        function isDriverStationary(driverDot, idx) {
            const cur     = driverDot.rawPoints[idx];
            const cutoff  = new Date(cur.date).getTime() - STATIONARY_HIDE_MS;
            let lookback  = idx;
            while (lookback > 0 && new Date(driverDot.rawPoints[lookback].date).getTime() > cutoff) lookback--;
            const past = driverDot.rawPoints[lookback];
            return Math.sqrt((cur.x - past.x) ** 2 + (cur.y - past.y) ** 2) < STATIONARY_MOVE_THRESHOLD;
        }

        // ── Scrubber ──────────────────────────────────────────
        function updateAllDriversToTime(targetTime) {
            for (const d of driverDots) {
                if (new Date(d.rawPoints[d.index].date).getTime() > targetTime) d.index = 0;
                while (d.index < d.rawPoints.length - 1 && new Date(d.rawPoints[d.index + 1].date).getTime() < targetTime) d.index++;
                const p = d.mappedPoints[d.index];
                d.dotMesh.position.set(p.x, p.y, 1);
                d.dotMesh.visible = !isDriverStationary(d, d.index);
            }
            const elapsed = targetTime - earliestTime;
            timeDisplay.textContent  = formatTime(elapsed);
            timelineScrubber.value   = String(Math.round((elapsed / totalDuration) * 1000));
            updateIntervalTower(targetTime);
            renderer.render(scene, camera);
        }

        timelineScrubber.addEventListener('mousedown', () => {
            isScrubbing = true; isPlaying = false; lastRealTime = null;
            document.getElementById('play-pause-button').textContent = 'Play';
            dismissRadio();
        });
        timelineScrubber.addEventListener('input', () => {
            simulatedTime = earliestTime + (Number(timelineScrubber.value) / 1000) * totalDuration;
            updateAllDriversToTime(simulatedTime);
        });
        timelineScrubber.addEventListener('mouseup', () => { isScrubbing = false; });

        // ── Animation loop ────────────────────────────────────
        let lastTowerUpdate = 0;

        function animate(ts) {
            requestAnimationFrame(animate);
            if (!isPlaying || isScrubbing) return;
            if (lastRealTime === null) lastRealTime = ts;
            simulatedTime += (ts - lastRealTime) * Number(document.getElementById('speed-select').value);
            lastRealTime = ts;

            let reachedEnd = true;
            for (const d of driverDots) {
                while (d.index < d.rawPoints.length - 1 && new Date(d.rawPoints[d.index + 1].date).getTime() < simulatedTime) d.index++;
                if (d.index < d.rawPoints.length - 1) reachedEnd = false;
                const p = d.mappedPoints[d.index];
                d.dotMesh.position.set(p.x, p.y, 1);
                d.dotMesh.visible = !isDriverStationary(d, d.index);
            }

            if (reachedEnd) {
                isPlaying = false; lastRealTime = null;
                document.getElementById('play-pause-button').textContent = 'Play';
            }

            const elapsed = simulatedTime - earliestTime;
            timeDisplay.textContent = formatTime(elapsed);
            timelineScrubber.value  = String(Math.round((elapsed / totalDuration) * 1000));

            if (ts - lastTowerUpdate > 500) { updateIntervalTower(simulatedTime); lastTowerUpdate = ts; }
            renderer.render(scene, camera);
        }

        document.getElementById('play-pause-button')?.addEventListener('click', () => {
            isPlaying = !isPlaying; lastRealTime = null;
            document.getElementById('play-pause-button').textContent = isPlaying ? 'Pause' : 'Play';
        });

        requestAnimationFrame(animate);
    }

    // ── Load button ───────────────────────────────────────────
    document.getElementById('load-track-button')?.addEventListener('click', async () => {
        await startTrackLoad();
    });
</script>