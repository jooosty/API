---
---
<div id="visualiser-section">
<div class="visualiser-header">
    <h2>Track Visualiser</h2>
    <span id="active-session-label" class="active-session-label"></span>
</div>
<div class="visualiser-controls">
    <button id="load-track-button" class="primary">Load Track</button>
    <label for="speed-select">Speed:</label>
    <select id="speed-select">
        <option value="1">1x</option>
        <option value="2">2x</option>
        <option value="5">5x</option>
        <option value="10" selected>10x</option>
        <option value="25">25x</option>
        <option value="50">50x</option>
    </select>
    <button id="play-pause-button" disabled>Pause</button>
</div>
<div class="visualiser-layout">
    <div class="track-wrap">
        <div id="track-container"></div>
        <div id="interval-tower">
            <div class="tower-header" style="display:flex;justify-content:space-between;align-items:center;padding:4px 8px;">
                <span>Intervals</span>
                <span id="lap-counter" style="font-size:10px;color:#f0c040;font-family:var(--mono);letter-spacing:0.06em;"></span>
            </div>
            <div id="phase-indicator"></div>
            <div id="interval-rows">
                <div class="tower-empty">Load track to show</div>
            </div>
        </div>
        <div id="weather-overlay">
            <span id="wx-track">—</span><span class="wx-label">TRK</span>
            <span id="wx-air">—</span><span class="wx-label">AIR</span>
            <span id="wx-humid">—</span><span class="wx-label">HUM</span>
            <span id="wx-wind">—</span><span class="wx-label">WND</span>
            <span id="wx-rain" class="wx-rain-badge">DRY</span>
        </div>
        <div id="radio-popup" class="radio-popup hidden">
            <div class="radio-popup-header">
                <span id="radio-dot" class="radio-dot"></span>
                <span id="radio-acronym" class="radio-acronym"></span>
                <span class="radio-live-badge">RADIO</span>
                <button id="radio-close" class="radio-close">✕</button>
            </div>
            <div class="radio-popup-controls">
                <button id="radio-play-btn" class="radio-play-btn">▶ Play</button>
                <div class="radio-progress-wrap">
                    <div id="radio-progress-bar" class="radio-progress-bar"></div>
                </div>
                <span id="radio-time" class="radio-time">0:00</span>
            </div>
        </div>
        <canvas id="telemetry-hud" width="160" height="160" style="position:absolute;bottom:40px;left:50%;transform:translateX(-50%);width:120px;height:120px;pointer-events:none;display:none;z-index:15;border-radius:6px;"></canvas>
        <div id="focus-badge" style="display:none;position:absolute;top:10px;left:50%;transform:translateX(-50%);display:none;align-items:center;gap:8px;background:rgba(6,8,14,0.88);border:1px solid #333;border-radius:6px;padding:5px 10px 5px 8px;font-family:var(--mono);z-index:20;pointer-events:auto;">
            <span id="focus-dot" style="display:inline-block;width:8px;height:8px;border-radius:50%;flex-shrink:0;"></span>
            <span id="focus-name" style="font-size:11px;font-weight:700;letter-spacing:0.06em;color:#fff;"></span>
            <span style="font-size:9px;color:#555;letter-spacing:0.1em;">FOCUS</span>
            <button id="focus-exit" style="background:none;border:none;color:#555;font-size:11px;cursor:pointer;padding:0 2px;line-height:1;">✕</button>
        </div>
        <div class="timeline-row">
            <span id="time-display">0:00</span>
            <input type="range" id="timeline-scrubber" min="0" max="1000" value="0" disabled />
            <span id="time-total"></span>
        </div>
    </div>
    <div id="live-lap-tower">
        <div class="tower-header">On Lap</div>
        <div id="live-lap-rows">
            <div class="tower-empty">Load track to show</div>
        </div>
    </div>
    <div id="pit-tower">
        <div class="tower-header">Pit Stops</div>
        <div id="pit-tower-rows">
            <div class="tower-empty">Load track to show</div>
        </div>
    </div>
    <div id="overtake-tower">
        <div class="tower-header">Overtakes</div>
        <div id="overtake-rows">
            <div class="tower-empty">Load track to show</div>
        </div>
    </div>
    <div id="race-control-tower">
        <div class="tower-header">Race Control</div>
        <div id="race-control-rows">
            <div class="tower-empty">Load track to show</div>
        </div>
    </div>
</div>
</div>

<script>
    import * as THREE from 'three';
    import { createScene, createCamera, createRenderer, createLoadingSprite, buildCoordTransform, buildTrackGeometry, buildDriverDots, setupDotClickDetection } from '../scripts/track-scene.js';
    import { setupDriverTrails } from '../scripts/track-overlays.js';
    import { setupCameraControls } from '../scripts/track-camera.js';
    import { createApiFetcher, fetchSessionData, fetchTowerData, buildDriverInfoMap, fetchLocationData } from '../scripts/track-data.js';
    import { setupRadio } from '../scripts/track-radio.js';
    import { setupTelemetry } from '../scripts/track-telemetry.js';
    import { setupPlayback } from '../scripts/track-playback.js';

    const scene    = createScene();
    const camera   = createCamera();
    const renderer = createRenderer();
    document.getElementById('track-container')?.appendChild(renderer.domElement);

    function setLoadControls(isLoading) {
        const loadButton       = document.getElementById('load-track-button');
        const playPauseButton  = document.getElementById('play-pause-button');
        const timelineScrubber = document.getElementById('timeline-scrubber');
        if (loadButton)       { loadButton.disabled = isLoading; loadButton.textContent = isLoading ? 'Loading...' : 'Reload'; }
        if (playPauseButton)  playPauseButton.disabled  = isLoading;
        if (timelineScrubber) timelineScrubber.disabled = isLoading;
    }

    let currentSessionKey = null;
    window.addEventListener('session-changed', (e) => {
        currentSessionKey = e.detail.sessionKey;
        const label = document.getElementById('active-session-label');
        if (label) label.textContent = `${e.detail.meetingName} — ${e.detail.sessionName}`;
        void startTrackLoad();
    });

    async function startTrackLoad() {
        setLoadControls(true);
        try { await loadTrack(); } finally { setLoadControls(false); }
    }

    async function loadTrack() {
        const sessionKey = currentSessionKey;
        if (!sessionKey) { alert('Please select a session first.'); return; }

        const { sprite: loadingSprite, setText: setLoadingText } = createLoadingSprite(scene, camera, renderer);

        setLoadingText('Fetching session...');
        scene.clear();
        scene.background = new THREE.Color(0x1a1a1a);
        scene.add(loadingSprite);
        renderer.render(scene, camera);

        const apiFetch = createApiFetcher(setLoadingText);

        // ── Fetch all data ────────────────────────────────────
        const { sessionData, driversData, isPractice, isQualifying } = await fetchSessionData(apiFetch, sessionKey, setLoadingText);
        const towerData = await fetchTowerData(apiFetch, sessionKey, isPractice, isQualifying, setLoadingText);
        const driverInfoMap = buildDriverInfoMap(driversData);
        const allDriverLocationData = await fetchLocationData(apiFetch, sessionKey, sessionData, driversData, setLoadingText);

        scene.remove(loadingSprite);

        // ── Build scene ───────────────────────────────────────
        const toTrackPoint = buildCoordTransform(allDriverLocationData);
        const refDriver    = buildTrackGeometry(scene, allDriverLocationData, toTrackPoint);
        const driverDots   = buildDriverDots(scene, allDriverLocationData, driverInfoMap, toTrackPoint);

        // ── Camera controls ───────────────────────────────────
        const cameraCtrl = setupCameraControls(camera, renderer, () => renderer.render(scene, camera));

        // ── Radio + telemetry ─────────────────────────────────
        const radio     = setupRadio(driverInfoMap);
        const telemetry = setupTelemetry(driverInfoMap, apiFetch, sessionKey, renderer, camera, scene);

        // ── Focus mode ────────────────────────────────────────
        const focusBadge = document.getElementById('focus-badge');
        const focusDot   = document.getElementById('focus-dot');
        const focusName  = document.getElementById('focus-name');
        const focusExit  = document.getElementById('focus-exit');

        function enterFocus(driverNum, dot) {
            const info = driverInfoMap[driverNum] || { acronym: '#' + driverNum, colour: '#fff' };
            focusDot.style.background = info.colour;
            focusName.textContent     = info.acronym;
            focusBadge.style.display  = 'flex';
            cameraCtrl.focusDriver(dot);
            telemetry.select(driverNum);   // also open telemetry panel
        }

        function exitFocus() {
            focusBadge.style.display = 'none';
            cameraCtrl.unfocus();
        }

        focusExit.addEventListener('click', exitFocus);

        setupDotClickDetection(
            renderer, camera, driverDots, allDriverLocationData,
            (driverNum, dot) => enterFocus(driverNum, dot),
            exitFocus
        );

        // ── Playback ──────────────────────────────────────────
        setupPlayback({
            scene, camera, renderer,
            driverDots, allDriverLocationData,
            setupDriverTrails,
            cameraCtrl,
            ...towerData,
            driverInfoMap, isPractice, isQualifying,
            radio, telemetry,
            apiFetch, sessionKey,
        });
    }

    document.getElementById('load-track-button')?.addEventListener('click', async () => {
        await startTrackLoad();
    });
</script>