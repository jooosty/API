---
---
<div id="visualiser-section">
<div class="visualiser-header">
    <h2>Track Visualiser</h2>
    <span id="active-session-label" class="active-session-label"></span>
</div>
<div class="visualiser-controls">
    <button id="load-track-button" class="primary">Load Track</button>
    <label for="speed-select">Speed:</label>
    <select id="speed-select">
        <option value="1">1x</option>
        <option value="2">2x</option>
        <option value="5">5x</option>
        <option value="10" selected>10x</option>
        <option value="25">25x</option>
        <option value="50">50x</option>
    </select>
    <button id="play-pause-button" disabled>Pause</button>
</div>
<div class="visualiser-layout">
    <div class="track-wrap">
        <div id="track-container"></div>
        <button id="pip-button" class="pip-button" title="Picture in Picture">⧉</button>
        <div id="podium-overlay" class="podium-overlay tower-hidden"></div>
        <div id="loading-overlay" class="loading-overlay tower-hidden">
            <video id="loading-video" class="loading-video" playsinline>
                <source id="loading-video-src" src="" type="video/mp4">
            </video>
            <div id="loading-status" class="loading-status"></div>
            <button id="skip-intro" class="skip-intro tower-hidden">Skip Intro ›</button>
        </div>
        <div id="interval-tower" class="tower-hidden">
            <div class="tower-header tower-header--split">
                <span>Intervals</span>
                <span id="lap-counter" class="lap-counter"></span>
            </div>
            <div id="phase-indicator"></div>
            <div id="interval-rows">
                <div class="tower-empty">Load track to show</div>
            </div>
        </div>
        <div id="weather-overlay">
            <span id="wx-track">—</span><span class="wx-label">TRK</span>
            <span id="wx-air">—</span><span class="wx-label">AIR</span>
            <span id="wx-humid">—</span><span class="wx-label">HUM</span>
            <span id="wx-wind">—</span><span class="wx-label">WND</span>
            <span id="wx-rain" class="wx-rain-badge">DRY</span>
        </div>
        <div id="radio-popup" class="radio-popup hidden">
            <div class="radio-popup-header">
                <span id="radio-dot" class="radio-dot"></span>
                <span id="radio-acronym" class="radio-acronym"></span>
                <span class="radio-live-badge">RADIO</span>
                <button id="radio-close" class="radio-close">✕</button>
            </div>
            <div class="radio-popup-controls">
                <button id="radio-play-btn" class="radio-play-btn">▶ Play</button>
                <div class="radio-progress-wrap">
                    <div id="radio-progress-bar" class="radio-progress-bar"></div>
                </div>
                <span id="radio-time" class="radio-time">0:00</span>
            </div>
        </div>
        <canvas id="telemetry-hud" width="160" height="160"></canvas>
        <div id="focus-badge" class="focus-badge">
            <span id="focus-dot" class="focus-dot"></span>
            <span id="focus-name" class="focus-name"></span>
            <span class="focus-label">FOCUS</span>
            <button id="focus-exit" class="focus-exit">✕</button>
        </div>
        <div class="timeline-row">
            <span id="time-display">0:00</span>
            <input type="range" id="timeline-scrubber" min="0" max="1000" value="0" disabled />
            <span id="time-total"></span>
        </div>
    </div>
    <div id="live-lap-tower" class="tower-hidden">
        <div class="tower-header">On Lap</div>
        <div id="live-lap-rows">
            <div class="tower-empty">Load track to show</div>
        </div>
    </div>
    <div id="pit-tower" class="tower-hidden">
        <div class="tower-header">Pit Stops</div>
        <div id="pit-tower-rows">
            <div class="tower-empty">Load track to show</div>
        </div>
    </div>
    <div id="overtake-tower" class="tower-hidden">
        <div class="tower-header">Overtakes</div>
        <div id="overtake-rows">
            <div class="tower-empty">Load track to show</div>
        </div>
    </div>
    <div id="race-control-tower" class="tower-hidden">
        <div class="tower-header">Race Control</div>
        <div id="race-control-rows">
            <div class="tower-empty">Load track to show</div>
        </div>
    </div>
    <div id="comparison-panel" class="tower-hidden">
        <div class="tower-header tower-header--split"><span>Comparison</span><span class="tower-header-hint">right-click driver</span></div>
        <div id="comparison-rows">
            <div class="comp-empty">Right-click a driver to compare</div>
        </div>
    </div>
</div>
</div>

<script>
    import * as THREE from 'three';
    import { createScene, createCamera, createRenderer, buildCoordTransform, buildTrackGeometry, buildDriverDots, setupDotClickDetection } from '../scripts/track-scene.js';
    import { setupDriverTrails } from '../scripts/track-overlays.js';
    import { setupCameraControls } from '../scripts/track-camera.js';
    import { createApiFetcher, fetchSessionData, fetchTowerData, buildDriverInfoMap, fetchLocationData } from '../scripts/track-data.js';
    import { setupRadio } from '../scripts/track-radio.js';
    import { setupTelemetry } from '../scripts/track-telemetry.js';
    import { setupPlayback } from '../scripts/track-playback.js';
    import { setupComparison } from '../scripts/session-comparison.js';
    import { setupTowerResize } from '../scripts/tower-resize.js';
    import '../scripts/easter-eggs.js';
    import { showPodium, hidePodium } from '../scripts/podium-screen.js';

    const scene    = createScene();
    const camera   = createCamera();
    const renderer = createRenderer();
    // Set up tower resize/collapse — runs once, persists across session loads
    setupTowerResize();

    document.getElementById('track-container')?.appendChild(renderer.domElement);

    // ── Picture in Picture ────────────────────────────────────
    document.getElementById('pip-button')?.addEventListener('click', async () => {
        const canvas = renderer.domElement;
        // Canvas PiP requires capturing a video stream from the canvas
        if (document.pictureInPictureElement) {
            await document.exitPictureInPicture();
            return;
        }
        try {
            // Create a hidden video fed by the canvas stream
            let pipVideo = document.getElementById('pip-video-el');
            if (!pipVideo) {
                pipVideo = document.createElement('video');
                pipVideo.id  = 'pip-video-el';
                pipVideo.style.cssText = 'position:fixed;opacity:0;pointer-events:none;width:1px;height:1px;';
                pipVideo.muted = true;
                document.body.appendChild(pipVideo);
            }
            // Capture at ~30fps
            const stream = canvas.captureStream(30);
            pipVideo.srcObject = stream;
            await pipVideo.play();
            await pipVideo.requestPictureInPicture();

            pipVideo.addEventListener('leavepictureinpicture', () => {
                pipVideo.pause();
            }, { once: true });
        } catch (err) {
            console.warn('PiP not supported or denied:', err);
        }
    });

    function setLoadControls(isLoading) {
        const loadButton       = document.getElementById('load-track-button');
        const playPauseButton  = document.getElementById('play-pause-button');
        const timelineScrubber = document.getElementById('timeline-scrubber');
        if (loadButton)       { loadButton.disabled = isLoading; loadButton.textContent = isLoading ? 'Loading...' : 'Reload'; }
        if (playPauseButton)  playPauseButton.disabled  = isLoading;
        if (timelineScrubber) timelineScrubber.disabled = isLoading;
    }

    let currentSessionKey = null;
    let currentPlayback   = null;  // holds { destroy } from setupPlayback
    window.addEventListener('session-changed', (e) => {
        currentSessionKey = e.detail.sessionKey;
        const label = document.getElementById('active-session-label');
        if (label) label.textContent = `${e.detail.meetingName} — ${e.detail.sessionName}`;
        void startTrackLoad();
    });

    async function startTrackLoad() {
        // Stop the previous session's animation loop before starting a new one
        if (currentPlayback) { currentPlayback.destroy(); currentPlayback = null; }
        setLoadControls(true);
        try { await loadTrack(); } finally {
            setLoadControls(false);
        }
    }

    async function loadTrack() {
        const sessionKey = currentSessionKey;
        if (!sessionKey) { alert('Please select a session first.'); return; }

        // Clear previous scene, no loading sprite — theme music plays instead
        scene.clear();
        scene.background = new THREE.Color(0x1a1a1a);
        renderer.render(scene, camera);

        // Show loading video overlay
        const loadingOverlay = document.getElementById('loading-overlay');
        const loadingVideo   = document.getElementById('loading-video');
        const loadingVideoSrc = document.getElementById('loading-video-src');
        const loadingStatus  = document.getElementById('loading-status');

        // Pick theme video by current year — will retune once session year is known
        const THEME_VIDEOS = { 2023: '/themes/2023-F1.mp4', 2024: '/themes/2024-F1.mp4', 2025: '/themes/2025-F1.mp4' };
        function setThemeVideo(year) {
            const src = THEME_VIDEOS[Number(year)] || '/themes/2025-F1.mp4';
            if (loadingVideoSrc && loadingVideo && loadingVideoSrc.src !== location.origin + src) {
                loadingVideoSrc.src = src;
                loadingVideo.load();
                loadingVideo.play().catch(() => {});
            }
        }

        setThemeVideo(new Date().getFullYear());
        if (loadingOverlay) loadingOverlay.classList.remove('tower-hidden');

        const setLoadingText = (msg) => {
            console.debug('[loading]', msg);
            if (loadingStatus) loadingStatus.textContent = msg;
        };
        const apiFetch = createApiFetcher(setLoadingText);

        // ── Fetch all data ────────────────────────────────────
        const { sessionData, driversData, isPractice, isQualifying } = await fetchSessionData(apiFetch, sessionKey, setLoadingText);
        // Re-tune video to the session's actual year
        if (sessionData[0]?.year) setThemeVideo(sessionData[0].year);
        const towerData = await fetchTowerData(apiFetch, sessionKey, isPractice, isQualifying, setLoadingText);
        const driverInfoMap = buildDriverInfoMap(driversData);
        const allDriverLocationData = await fetchLocationData(apiFetch, sessionKey, sessionData, driversData, setLoadingText);


        // Data is ready — stop looping and show skip button
        const skipBtn = document.getElementById('skip-intro');
        if (loadingVideo && !loadingVideo.ended) {
            loadingVideo.loop = false;
            if (skipBtn) skipBtn.classList.remove('tower-hidden');

            await new Promise(resolve => {
                if (loadingVideo.ended || (loadingVideo.paused && loadingVideo.currentTime === 0)) {
                    resolve();
                } else {
                    const onEnd  = () => { cleanup(); resolve(); };
                    const onSkip = () => { cleanup(); loadingVideo.pause(); loadingVideo.src = ''; resolve(); };
                    function cleanup() {
                        loadingVideo.removeEventListener('ended', onEnd);
                        if (skipBtn) skipBtn.removeEventListener('click', onSkip);
                    }
                    loadingVideo.addEventListener('ended', onEnd, { once: true });
                    if (skipBtn) skipBtn.addEventListener('click', onSkip, { once: true });
                    setTimeout(resolve, Math.max((loadingVideo.duration || 30) * 1000, 30000));
                }
            });
        }
        if (skipBtn) skipBtn.classList.add('tower-hidden');
        if (loadingOverlay) loadingOverlay.classList.add('tower-hidden');

        // ── Build scene ───────────────────────────────────────
        const toTrackPoint = buildCoordTransform(allDriverLocationData);
        const refDriver    = buildTrackGeometry(scene, allDriverLocationData, toTrackPoint);
        const driverDots   = buildDriverDots(scene, allDriverLocationData, driverInfoMap, toTrackPoint);

        // ── Camera controls ───────────────────────────────────
        const cameraCtrl = setupCameraControls(camera, renderer, () => renderer.render(scene, camera));

        // ── Radio + telemetry ─────────────────────────────────
        const radio     = setupRadio(driverInfoMap);
        const telemetry = setupTelemetry(driverInfoMap, apiFetch, sessionKey, renderer, camera, scene);

        // ── Focus mode ────────────────────────────────────────
        const focusBadge = document.getElementById('focus-badge');
        const focusDot   = document.getElementById('focus-dot');
        const focusName  = document.getElementById('focus-name');
        const focusExit  = document.getElementById('focus-exit');

        function enterFocus(driverNum, dot) {
            const info = driverInfoMap[driverNum] || { acronym: '#' + driverNum, colour: '#fff' };
            focusDot.style.background = info.colour;
            focusName.textContent     = info.acronym;
            focusBadge.classList.remove('tower-hidden'); focusBadge.style.display = 'flex';
            cameraCtrl.focusDriver(dot);
            telemetry.select(driverNum);   // also open telemetry panel
        }

        function exitFocus() {
            focusBadge.classList.add('tower-hidden'); focusBadge.style.display = '';
            cameraCtrl.unfocus();
            // Also deselect telemetry if it was opened by focus mode
            if (telemetry.getSelectedDriver() !== null) telemetry.select(telemetry.getSelectedDriver());
        }

        focusExit.addEventListener('click', exitFocus);

        setupDotClickDetection(
            renderer, camera, driverDots, allDriverLocationData,
            (driverNum, dot) => enterFocus(driverNum, dot),
            exitFocus
        );

        // ── Playback ──────────────────────────────────────────
        // Show the right towers for this session type
        const isRace = !isPractice && !isQualifying;
        const towerVisibility = {
            'interval-tower':     true,
            'live-lap-tower':     isPractice || isQualifying,
            'pit-tower':          isRace,
            'overtake-tower':     isRace,
            'race-control-tower': true,
            'comparison-panel':   true,
        };
        for (const [id, show] of Object.entries(towerVisibility)) {
            const el = document.getElementById(id);
            if (el) el.classList.toggle('tower-hidden', !show);
        }

        // ── Session comparison ───────────────────────────────
        const comparison = setupComparison(towerData.allLapData, towerData.allStintData, driverInfoMap);

        currentPlayback = setupPlayback({
            scene, camera, renderer,
            driverDots, allDriverLocationData,
            setupDriverTrails,
            cameraCtrl,
            ...towerData,
            driverInfoMap, isPractice, isQualifying,
            radio, telemetry,
            comparison,
            allSessionResultData: towerData.allSessionResultData || [],
            showPodium, hidePodium,
            apiFetch, sessionKey,
        });
    }

    document.getElementById('load-track-button')?.addEventListener('click', async () => {
        await startTrackLoad();
    });
</script>