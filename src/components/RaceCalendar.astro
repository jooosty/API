---

---

<div id="calendar-section">

  <div class="calendar-hero-intro">
    <h1>F1 <span>Explorer</span></h1>
    <p>Select a session below to load the track visualiser</p>
    <div class="hero-arrow">↓</div>
  </div>

  <div class="calendar-toolbar">
    <h2>Season Calendar</h2>
    <div class="calendar-year-tabs" id="year-tabs">
      <button class="year-tab active" data-year="2025">2025</button>
      <button class="year-tab" data-year="2024">2024</button>
      <button class="year-tab" data-year="2023">2023</button>
    </div>
  </div>

  <div class="carousel-wrapper">
    <div class="carousel-track-outer">
      <div id="calendar-track" class="carousel-track">
        <div class="calendar-loading">Loading calendar...</div>
      </div>
    </div>
    <div class="carousel-nav">
      <button class="carousel-btn" id="carousel-prev">&#8592;</button>
      <div class="carousel-dots" id="carousel-dots"></div>
      <button class="carousel-btn" id="carousel-next">&#8594;</button>
    </div>
  </div>
</div>

<script>
  import { BASE_URL } from "../scripts/constants.js";

  const SESSION_LABELS = {
    "Practice 1": { short: "FP1", cls: "practice" },
    "Practice 2": { short: "FP2", cls: "practice" },
    "Practice 3": { short: "FP3", cls: "practice" },
    Sprint: { short: "SPR", cls: "sprint" },
    "Sprint Shootout": { short: "SQ", cls: "sprint" },
    Qualifying: { short: "Q", cls: "quali" },
    Race: { short: "R", cls: "race" },
  };

  const CARD_WIDTH = 300;
  const CARD_GAP = 12;
  const CARDS_VISIBLE = 3;

  let currentIndex = 0;
  let totalCards = 0;

  const track = document.getElementById("calendar-track");
  const dotsEl = document.getElementById("carousel-dots");

  function formatDate(iso) {
    if (!iso) return "";
    return new Date(iso).toLocaleDateString("en-GB", {
      day: "numeric",
      month: "short",
    });
  }

  function formatTime(iso) {
    if (!iso) return "";
    return new Date(iso).toLocaleTimeString("en-GB", {
      hour: "2-digit",
      minute: "2-digit",
    });
  }

  function countryFlagCode(code) {
    const map = {
      AUS: "au",
      CHN: "cn",
      JPN: "jp",
      BHR: "bh",
      BRN: "bh",
      SAU: "sa",
      KSA: "sa",
      USA: "us",
      ITA: "it",
      MCO: "mc",
      MON: "mc",
      CAN: "ca",
      ESP: "es",
      AUT: "at",
      GBR: "gb",
      HUN: "hu",
      BEL: "be",
      NLD: "nl",
      NED: "nl",
      AZE: "az",
      SGP: "sg",
      MEX: "mx",
      BRA: "br",
      UAE: "ae",
      QAT: "qa",
      MYS: "my",
      LAS: "us",
    };
    return map[code] || "";
  }

  function slideTo(index) {
    currentIndex = Math.max(0, Math.min(index, totalCards - CARDS_VISIBLE));
    const offset = currentIndex * (CARD_WIDTH + CARD_GAP);
    track.style.transform = `translateX(-${offset}px)`;
    document.querySelectorAll(".carousel-dot").forEach((dot, i) => {
      dot.classList.toggle("active", i === currentIndex);
    });
  }

  function buildDots(count) {
    dotsEl.innerHTML = "";
    const dotCount = Math.max(0, count - CARDS_VISIBLE + 1);
    for (let i = 0; i < dotCount; i++) {
      const dot = document.createElement("button");
      dot.className = "carousel-dot" + (i === 0 ? " active" : "");
      dot.addEventListener("click", () => slideTo(i));
      dotsEl.appendChild(dot);
    }
  }

  document
    .getElementById("carousel-prev")
    ?.addEventListener("click", () => slideTo(currentIndex - 1));
  document
    .getElementById("carousel-next")
    ?.addEventListener("click", () => slideTo(currentIndex + 1));

  // keyboard navigation
  document.addEventListener("keydown", (e) => {
    if (e.key === "ArrowLeft") slideTo(currentIndex - 1);
    if (e.key === "ArrowRight") slideTo(currentIndex + 1);
  });

  // ── Touch / mouse drag scrolling ──────────────────────────
  const trackOuter = document.querySelector(".carousel-track-outer");
  let dragStartX   = 0;
  let dragDeltaX   = 0;
  let isDragging   = false;

  function onDragStart(x) {
    isDragging  = true;
    dragStartX  = x;
    dragDeltaX  = 0;
    track.style.transition = "none"; // disable transition while dragging
  }

  function onDragMove(x) {
    if (!isDragging) return;
    dragDeltaX = x - dragStartX;
    // Live-drag the track
    const baseOffset = currentIndex * (CARD_WIDTH + CARD_GAP);
    track.style.transform = `translateX(${-baseOffset + dragDeltaX}px)`;
  }

  function onDragEnd() {
    if (!isDragging) return;
    isDragging = false;
    track.style.transition = ""; // restore CSS transition

    // Calculate how many cards were dragged across, then snap to nearest
    const cardSize   = CARD_WIDTH + CARD_GAP;
    const cardsMoved = Math.round(-dragDeltaX / cardSize);
    slideTo(currentIndex + cardsMoved);
  }

  // Mouse events
  trackOuter.addEventListener("mousedown",  e => { e.preventDefault(); onDragStart(e.clientX); });
  window.addEventListener("mousemove",      e => { onDragMove(e.clientX); });
  window.addEventListener("mouseup",        ()  => { onDragEnd(); });

  // Touch events
  trackOuter.addEventListener("touchstart", e => { onDragStart(e.touches[0].clientX); }, { passive: true });
  trackOuter.addEventListener("touchmove",  e => { onDragMove(e.touches[0].clientX); },  { passive: true });
  trackOuter.addEventListener("touchend",   ()  => { onDragEnd(); });

  async function loadCalendar(year) {
    track.innerHTML = '<div class="calendar-loading">Loading calendar...</div>';
    track.style.transform = "translateX(0)";
    dotsEl.innerHTML = "";
    currentIndex = 0;

    const [meetings, sessions] = await Promise.all([
      fetch(`${BASE_URL}/meetings?year=${year}`).then((r) => r.json()),
      fetch(`${BASE_URL}/sessions?year=${year}`).then((r) => r.json()),
    ]);

    meetings.sort((a, b) => new Date(a.date_start) - new Date(b.date_start));

    const sessionsByMeeting = {};
    for (const s of sessions) {
      if (!sessionsByMeeting[s.meeting_key])
        sessionsByMeeting[s.meeting_key] = [];
      sessionsByMeeting[s.meeting_key].push(s);
    }
    for (const key of Object.keys(sessionsByMeeting)) {
      sessionsByMeeting[key].sort(
        (a, b) => new Date(a.date_start) - new Date(b.date_start),
      );
    }

    const now = Date.now();
    totalCards = meetings.length;
    track.innerHTML = "";

    let nextFound = false;

    meetings.forEach((meeting, idx) => {
      const meetingSessions = sessionsByMeeting[meeting.meeting_key] || [];
      const lastSession = meetingSessions[meetingSessions.length - 1];
      const isPast = lastSession
        ? new Date(lastSession.date_end || lastSession.date_start) < now
        : new Date(meeting.date_start) < now;
      const isNext = !isPast && !nextFound;
      if (isNext) nextFound = true;

      const card = document.createElement("div");
      card.className = `race-card${isPast ? " past" : ""}${isNext ? " next" : ""}`;

      // header
      const header = document.createElement("div");
      header.className = "race-card-header";

      if (isNext) {
        const nextBadge = document.createElement("span");
        nextBadge.className = "next-badge";
        nextBadge.textContent = "NEXT";
        header.appendChild(nextBadge);
      }

      const round = document.createElement("span");
      round.className = "race-round";
      round.textContent = `R${String(idx + 1).padStart(2, "0")}`;

      const flag = document.createElement("img");
      flag.className = "race-flag";
      const flagCode = countryFlagCode(meeting.country_code);
      if (flagCode) {
        flag.src = `https://flagcdn.com/w40/${flagCode}.png`;
        flag.alt = `${meeting.country_code} flag`;
        flag.width = 20;
        flag.height = 15;
        flag.loading = "lazy";
      }

      const name = document.createElement("div");
      name.className = "race-name";
      name.textContent = meeting.meeting_name;

      const dateRange = document.createElement("div");
      dateRange.className = "race-date-range";
      dateRange.textContent = formatDate(meeting.date_start);

      header.appendChild(round);
      header.appendChild(flag);
      header.appendChild(name);
      header.appendChild(dateRange);
      card.appendChild(header);

      // sessions
      const sessionsEl = document.createElement("div");
      sessionsEl.className = "race-sessions";

      meetingSessions.forEach((session) => {
        const meta = SESSION_LABELS[session.session_name] || {
          short: session.session_name,
          cls: "other",
        };
        const sessionEl = document.createElement("div");
        sessionEl.className = `session-row session-${meta.cls}`;
        if (new Date(session.date_end || session.date_start) < now) {
          sessionEl.classList.add("session-past");
        }

        const left = document.createElement("div");
        left.className = "session-left";

        const badge = document.createElement("span");
        badge.className = "session-badge";
        badge.textContent = meta.short;

        const sessionName = document.createElement("span");
        sessionName.className = "session-name";
        sessionName.textContent = session.session_name;

        left.appendChild(badge);
        left.appendChild(sessionName);

        const right = document.createElement("div");
        right.className = "session-right";

        const date = document.createElement("span");
        date.className = "session-date";
        date.textContent = formatDate(session.date_start);

        const time = document.createElement("span");
        time.className = "session-time";
        time.textContent = formatTime(session.date_start);

        right.appendChild(date);
        right.appendChild(time);

        const loadBtn = document.createElement("button");
        loadBtn.className = "session-load-btn";
        loadBtn.textContent = "Load";
        loadBtn.addEventListener("click", () => {
          document.querySelectorAll(".session-load-btn.active").forEach((b) => {
            b.textContent = "Load";
            b.classList.remove("active");
          });
          loadBtn.textContent = "Loaded";
          loadBtn.classList.add("active");
          window.dispatchEvent(
            new CustomEvent("session-changed", {
              detail: {
                sessionKey: session.session_key,
                sessionName: session.session_name,
                meetingName: meeting.meeting_name,
              },
            }),
          );
          document
            .getElementById("visualiser-section")
            ?.scrollIntoView({ behavior: "smooth", block: "start" });
        });

        sessionEl.appendChild(left);
        sessionEl.appendChild(right);
        sessionEl.appendChild(loadBtn);
        sessionsEl.appendChild(sessionEl);
      });

      card.appendChild(sessionsEl);
      track.appendChild(card);

      // auto-scroll carousel to next race
      if (isNext) {
        const targetIndex = Math.max(0, idx - 1);
        setTimeout(() => slideTo(targetIndex), 50);
      }
    });

    buildDots(totalCards);
  }

  document.querySelectorAll(".year-tab").forEach((tab) => {
    tab.addEventListener("click", () => {
      document
        .querySelectorAll(".year-tab")
        .forEach((t) => t.classList.remove("active"));
      tab.classList.add("active");
      loadCalendar(tab.dataset.year);
    });
  });

  loadCalendar("2025");
</script>